---
/**
 * Auto-playing screenshot carousel meant to live inside <IPhoneFrame>.
 * Crossfades between any number of images. Static first image under
 * prefers-reduced-motion.
 */
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

interface Props {
  images: { src: ImageMetadata; alt: string }[]
  priority?: boolean
}

const { images, priority = false } = Astro.props

const perSlide = 3 // seconds each image stays fully visible
const total = images.length * perSlide
const name = `carousel-fade-${images.length}`

// keyframe windows as a percentage of the whole loop
const fadeIn = ((0.4 / total) * 100).toFixed(2)
const holdEnd = (((perSlide - 0.4) / total) * 100).toFixed(2)
const fadeOut = ((perSlide / total) * 100).toFixed(2)

const keyframes = `@keyframes ${name}{0%{opacity:0}${fadeIn}%{opacity:1}${holdEnd}%{opacity:1}${fadeOut}%{opacity:0}100%{opacity:0}}`
---

<style is:inline set:html={keyframes}></style>

<div class="carousel" aria-label={images[0]?.alt} style={`--total:${total}s`}>
  {
    images.map((img, i) => (
      <Image
        src={img.src}
        alt={img.alt}
        widths={[320, 480, 720, 1206]}
        sizes="(max-width: 768px) 76vw, 340px"
        loading={priority && i === 0 ? 'eager' : 'lazy'}
        fetchpriority={priority && i === 0 ? 'high' : 'auto'}
        style={`animation-name:${name};animation-delay:${i * perSlide}s`}
      />
    ))
  }
</div>

<style>
  .carousel {
    position: absolute;
    inset: 0;
  }

  .carousel :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    animation-duration: var(--total);
    animation-iteration-count: infinite;
    animation-timing-function: linear;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel :global(img) {
      animation: none;
    }

    .carousel :global(img:first-child) {
      opacity: 1;
    }
  }
</style>
