---
// Decorative auto-rotating 3D model. The model-viewer custom element (three.js
// inside, ~210 KB gzip) is only imported once the element nears the viewport.
// The GLB is generated with the ring-stack axis at x=0/z=0 so the fixed
// camera-target makes both the turntable and the camera pivot on that axis.
interface Props {
  src: string
  alt: string
}

const { src, alt } = Astro.props
---

<model-viewer
  src={src}
  alt={alt}
  auto-rotate
  auto-rotate-delay="0"
  rotation-per-second="18deg"
  disable-zoom
  disable-pan
  disable-tap
  interaction-prompt="none"
  camera-target="0m 0m 0m"
  camera-orbit="30deg 78deg auto"
  field-of-view="28deg"
  shadow-intensity="0.6"
  exposure="1.1"
  loading="lazy"
></model-viewer>

<script>
  const BASE_ORBIT = '30deg 78deg auto'

  // While the pointer is over the card, the model stops spinning and turns
  // toward the cursor; it resumes spinning when the pointer leaves.
  const followPointer = (viewer: Element) => {
    const card = viewer.closest('.proof-card') ?? viewer
    card.addEventListener('pointermove', (event) => {
      const { clientX, clientY } = event as PointerEvent
      const rect = card.getBoundingClientRect()
      const nx = Math.min(1, Math.max(-1, ((clientX - rect.left) / rect.width) * 2 - 1))
      const ny = Math.min(1, Math.max(-1, ((clientY - rect.top) / rect.height) * 2 - 1))
      viewer.removeAttribute('auto-rotate')
      viewer.setAttribute('camera-orbit', `${30 + nx * 35}deg ${78 - ny * 20}deg auto`)
    })
    card.addEventListener('pointerleave', () => {
      viewer.setAttribute('camera-orbit', BASE_ORBIT)
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        viewer.setAttribute('auto-rotate', '')
      }
    })
  }

  const lazyLoad = () => {
    const viewers = document.querySelectorAll('model-viewer')
    if (viewers.length === 0) return
    // model-viewer 4.x keeps auto-rotating despite prefers-reduced-motion
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reducedMotion) {
      for (const viewer of viewers) viewer.removeAttribute('auto-rotate')
    }
    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect()
          import('@google/model-viewer')
        }
      },
      { rootMargin: '400px' },
    )
    for (const viewer of viewers) {
      io.observe(viewer)
      followPointer(viewer)
    }
  }
  lazyLoad()
</script>

<style>
  model-viewer {
    display: block;
    width: 100%;
    height: 100%;
    background: transparent;
    --poster-color: transparent;
  }
</style>
