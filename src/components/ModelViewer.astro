---
// Decorative auto-rotating 3D model. The model-viewer custom element (three.js
// inside, ~210 KB gzip) is only imported once the element nears the viewport.
// The GLB is generated with the ring-stack axis at x=0/z=0 so the fixed
// camera-target makes both the turntable and the camera pivot on that axis.
interface Props {
  src?: string
  // when set, the viewer cycles through these GLBs one by one (see cycleSeconds)
  sources?: string[]
  cycleSeconds?: number
  alt: string
  cameraOrbit?: string
  fieldOfView?: string
  autoRotate?: boolean
  interactive?: boolean
  // 'legacy' gives a directional key light that shades flat white prints far
  // better than the default neutral environment
  environmentImage?: string
  exposure?: string
}

const {
  src,
  sources,
  cycleSeconds = 3.5,
  alt,
  cameraOrbit = '30deg 78deg auto',
  fieldOfView = '28deg',
  autoRotate = true,
  interactive = true,
  environmentImage,
  exposure = '1.1',
} = Astro.props

const initialSrc = sources?.[0] ?? src
---

<model-viewer
  src={initialSrc}
  alt={alt}
  data-cycle={sources ? JSON.stringify(sources) : undefined}
  data-cycle-seconds={sources ? String(cycleSeconds) : undefined}
  data-static={interactive ? undefined : ''}
  auto-rotate={autoRotate ? '' : undefined}
  auto-rotate-delay="0"
  rotation-per-second="18deg"
  disable-zoom
  disable-pan
  disable-tap
  interaction-prompt="none"
  camera-target="0m 0m 0m"
  camera-orbit={cameraOrbit}
  field-of-view={fieldOfView}
  shadow-intensity="0.6"
  environment-image={environmentImage}
  exposure={exposure}
  loading="lazy"
></model-viewer>

<script>
  // While the pointer is over the card, the model stops spinning and the
  // cursor fully drives its orientation: sweeping the card left to right spins
  // it a full turn, top to bottom tips it right over. It resumes spinning when
  // the pointer leaves. The zoom (orbit radius) is kept from the element's
  // initial camera-orbit so per-card framing survives the hover.
  const followPointer = (viewer: Element) => {
    const base = viewer.getAttribute('camera-orbit') ?? '30deg 78deg auto'
    const radius = base.trim().split(/\s+/)[2] ?? 'auto'
    // a model that starts without auto-rotate (a fixed pose) must not start
    // spinning when the pointer leaves, only return to its base orientation
    const spins = viewer.hasAttribute('auto-rotate')
    const card = viewer.closest('.proof-card') ?? viewer
    card.addEventListener('pointermove', (event) => {
      const { clientX, clientY } = event as PointerEvent
      const rect = card.getBoundingClientRect()
      const nx = Math.min(1, Math.max(-1, ((clientX - rect.left) / rect.width) * 2 - 1))
      const ny = Math.min(1, Math.max(-1, ((clientY - rect.top) / rect.height) * 2 - 1))
      viewer.removeAttribute('auto-rotate')
      // full azimuth sweep (-180deg..180deg) and near-full polar tilt (~15deg..165deg)
      viewer.setAttribute('camera-orbit', `${nx * 180}deg ${90 - ny * 75}deg ${radius}`)
    })
    card.addEventListener('pointerleave', () => {
      viewer.setAttribute('camera-orbit', base)
      if (spins && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        viewer.setAttribute('auto-rotate', '')
      }
    })
  }

  // A carousel viewer steps through its data-cycle list one model at a time.
  // Cycling pauses while the pointer is over the card so the visitor can freely
  // rotate the current model (followPointer drives it), then resumes on leave.
  // Static under prefers-reduced-motion: only the first model is ever shown.
  const cycleSources = (viewer: Element) => {
    let list: string[] = []
    try {
      list = JSON.parse(viewer.getAttribute('data-cycle') ?? '[]')
    } catch {
      list = []
    }
    if (list.length < 2) return
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
    const seconds = Number(viewer.getAttribute('data-cycle-seconds')) || 3.5
    const card = viewer.closest('.proof-card') ?? viewer
    const el = viewer as HTMLElement
    const slide = 'opacity 0.35s ease, transform 0.35s ease-in'
    const slideIn = 'opacity 0.35s ease, transform 0.35s ease-out'
    el.style.transition = slide
    let index = 0
    let paused = false
    card.addEventListener('pointerenter', () => (paused = true))
    card.addEventListener('pointerleave', () => (paused = false))
    setInterval(() => {
      if (paused) return
      index = (index + 1) % list.length
      const next = list[index]
      if (!next) return
      // carousel slide: the current bin exits to the left, the GLB is swapped,
      // then the next bin enters from the right once model-viewer reports it
      // loaded (with a safety timeout in case the load event never fires).
      let revealed = false
      const reveal = () => {
        if (revealed) return
        revealed = true
        el.style.transition = 'none'
        el.style.transform = 'translateX(55%)'
        void el.offsetWidth // flush so the jump to the right side is instant
        el.style.transition = slideIn
        el.style.opacity = '1'
        el.style.transform = 'translateX(0)'
      }
      el.style.transition = slide
      el.style.opacity = '0'
      el.style.transform = 'translateX(-55%)'
      window.setTimeout(() => {
        viewer.addEventListener('load', reveal, { once: true })
        viewer.setAttribute('src', next)
        window.setTimeout(reveal, 1200)
      }, 350)
    }, seconds * 1000)
  }

  const lazyLoad = () => {
    const viewers = document.querySelectorAll('model-viewer')
    if (viewers.length === 0) return
    // model-viewer 4.x keeps auto-rotating despite prefers-reduced-motion
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reducedMotion) {
      for (const viewer of viewers) viewer.removeAttribute('auto-rotate')
    }
    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect()
          import('@google/model-viewer')
        }
      },
      { rootMargin: '400px' },
    )
    for (const viewer of viewers) {
      io.observe(viewer)
      // static viewers keep their fixed pose: no pointer-driven rotation
      if (!viewer.hasAttribute('data-static')) followPointer(viewer)
      if (viewer.hasAttribute('data-cycle')) cycleSources(viewer)
    }
  }
  lazyLoad()
</script>

<style>
  model-viewer {
    display: block;
    width: 100%;
    height: 100%;
    background: transparent;
    --poster-color: transparent;
  }
</style>
