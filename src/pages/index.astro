---
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import portrait from '../assets/portrait.jpg'
import appIcon from '../assets/vinarium/app-icon.png'
import cellarShot from '../assets/vinarium/cellar.png'
import dashboardShot from '../assets/vinarium/dashboard.png'
import scanReviewShot from '../assets/vinarium/scan-review.png'
import scanShot from '../assets/vinarium/scan.png'
import CryptoPhoneScreen from '../components/CryptoPhoneScreen.astro'
import PhoneCarousel from '../components/PhoneCarousel.astro'
import IPhoneFrame from '../components/IPhoneFrame.astro'
import Reveal from '../components/Reveal.astro'
import SiteFooter from '../components/SiteFooter.astro'
import StatCounter from '../components/StatCounter.astro'
import { cryptoBot } from '../data/crypto-bot'
import { site } from '../data/site'
import Base from '../layouts/Base.astro'

const method = [
  {
    n: '01',
    title: 'Reach & user flow',
    text: 'How will the product reach its users? Wireframes to understand the user flow, before one line of code.',
  },
  {
    n: '02',
    title: 'First iteration',
    text: 'A first usable version, quickly, on a stack that is scalable and robust to change.',
  },
  {
    n: '03',
    title: 'Rails for the LLM',
    text: 'Domain-driven architecture, strong typing, data visualization, CI/CD. Everything that helps Claude deliver with almost no errors.',
  },
  {
    n: '04',
    title: 'Run & protect',
    text: 'Sentry watches bugs and performance permanently. The infrastructure rebuilds with one command. The application and the data stay secured.',
  },
]

const timeline = [
  {
    period: 'Since Jan. 2026',
    role: 'Paternity leave',
    note: 'shipping CryptoBot & Vinarium with Claude',
  },
  { period: '2018 · 2025', role: 'Freelance full-stack developer & lead tech', note: 'Paris' },
  { period: '2017 · 2018', role: 'CTO', note: 'pupscan.com' },
  { period: '2016 · 2017', role: 'Web developer', note: 'Société Générale' },
  { period: '2014 · 2016', role: 'CTO', note: 'alantaya.com' },
]

const stack = [
  'TypeScript',
  'Swift · SwiftUI',
  'GraphQL · Pothos',
  'Nitro · Bun',
  'Firebase · GCP',
  'Firestore',
  'Terraform',
  'Docker',
  'Claude API',
  'Gemini API',
]
---

<Base
  title="Thibaut Mottet · Senior full-stack developer, the impact of a whole team"
  description="AI is changing software development. I bring the method, the architecture and the product vision, Claude writes the code. Real products in production, used every day."
  theme="home"
>
  <!-- Act 1 · Hero -->
  <header class="hero">
    <div class="container hero__inner">
      <Reveal delay={0.15} class="hero__card-wrap">
        <aside class="profile-card">
          <span class="profile-card__status">
            <span class="profile-card__status-dot"></span>
            Open to new missions
          </span>
          <div class="profile-card__head">
            <Image
              class="profile-card__avatar"
              src={portrait}
              alt="Portrait of Thibaut Mottet"
              width={160}
              height={160}
              loading="eager"
              fetchpriority="high"
            />
            <div class="profile-card__id">
              <strong>{site.name}</strong>
              <span>{site.role}</span>
              <span class="profile-card__location">
                <Icon name="lucide:map-pin" />
                {site.location}
              </span>
            </div>
            <div class="profile-card__links">
              <a href={site.github} rel="noopener" aria-label="GitHub">
                <Icon name="lucide:github" />
              </a>
              <a href={`mailto:${site.email}`} aria-label="Email">
                <Icon name="lucide:mail" />
              </a>
            </div>
          </div>
          <ol class="profile-card__timeline">
            {
              timeline.map((t) => (
                <li>
                  <span class="profile-card__period">{t.period}</span>
                  <strong>{t.role}</strong>
                  <span class="profile-card__note">{t.note}</span>
                </li>
              ))
            }
          </ol>
          <div class="profile-card__offer">
            <p class="profile-card__price">
              <strong>{site.dailyRate}&nbsp;€</strong><span>/ day</span>
            </p>
            <a class="profile-card__cta" href={`mailto:${site.email}`}>
              Hire me <Icon name="lucide:arrow-right" />
            </a>
          </div>
        </aside>
      </Reveal>
      <div class="hero__right">
        <div class="hero__text">
          <Reveal delay={0.08}>
            <h1 class="display">
              One senior developer.<br />The impact of a <span class="display__grad"
                >whole team</span
              >.
            </h1>
          </Reveal>
          <Reveal delay={0.15}>
            <p class="hero__lede">
              AI is changing our job, let's not pretend otherwise. What it still lacks is method,
              architecture and product vision. On my own, I now cover what used to need a full team:
              UI/UX, senior development, ops, security and data.
            </p>
          </Reveal>
        </div>
        <div class="proof__grid" id="proof">
          <Reveal>
          <a class="proof-card proof-card--crypto" href="/crypto-bot">
            <div class="proof-card__body">
              <p class="proof-card__eyebrow">CryptoBot</p>
              <p class="proof-card__sub">Grid trading, 24/7</p>
              <p class="proof-card__stat proof-card__stat--sm">
                <StatCounter value={cryptoBot.netPercent} decimals={2} prefix="+" suffix="%" />
              </p>
              <p class="proof-card__caption">net since April</p>
              <span class="proof-card__cta">See it work →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <CryptoPhoneScreen />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.1}>
          <a class="proof-card proof-card--vinarium" href="/vinarium">
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={appIcon}
                alt="Vinarium app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Vinarium · iOS</p>
              <p class="proof-card__title">A wine cellar that knows itself.</p>
              <p class="proof-card__caption">AI label scanning, live value, drink windows.</p>
              <span class="proof-card__cta">Take the tour →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <PhoneCarousel
                  images={[
                    { src: dashboardShot, alt: 'Vinarium dashboard' },
                    { src: scanShot, alt: 'Scanning a wine label' },
                    { src: scanReviewShot, alt: 'AI-filled wine record' },
                    { src: cellarShot, alt: 'Cellar map' },
                  ]}
                />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        </div>
      </div>
    </div>
  </header>

  <!-- Act 2 · The shift -->
  <section class="section">
    <div class="container--narrow">
      <Reveal><p class="eyebrow">The paradigm shift</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline shift__headline">
          AI is changing our profession. Let's not pretend otherwise.
        </h2>
      </Reveal>
      <Reveal group class="shift__copy">
        <p>
          Today, a senior developer with a good method can deliver what used to take a whole
          team. I see it every day: Claude writes excellent code, fast. The hard part has moved
          somewhere else.
        </p>
        <p>
          Because AI will not tell you to think about how to reach your customers, to draw
          wireframes to understand the user flow before coding, or to choose a stack that will
          survive three years of change. Product vision, methodology, architecture: this is where
          the human makes the difference. This is my job.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- Act 3 · How I work now -->
  <section class="section">
    <div class="container">
      <Reveal><p class="eyebrow">How I work now</p></Reveal>
      <Reveal delay={0.05}><h2 class="headline">What I bring</h2></Reveal>
      <Reveal group class="how__grid">
        <article class="card how__card">
          <h3>Product vision</h3>
          <p>
            How do we reach our customers? What is the user flow? Wireframes first, then a first
            iteration that real users can try. The code comes after the thinking.
          </p>
        </article>
        <article class="card how__card">
          <h3>Architecture that lasts</h3>
          <p>
            A stack that scales and accepts change: domain-driven boundaries, strong typing,
            CI/CD, an infrastructure easy to rebuild, the application and the data secured.
          </p>
        </article>
        <article class="card how__card">
          <h3>LLM supervision</h3>
          <p>
            Rails that help Claude deliver with the fewest errors possible: strict types, clear
            domains, code review on everything, and Sentry watching bugs and performance in
            production.
          </p>
        </article>
      </Reveal>
    </div>
  </section>

  <!-- Act 3b · The method, in practice -->
  <section class="section">
    <div class="container">
      <Reveal><p class="eyebrow">The method, in practice</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">From idea to production, every time</h2>
      </Reveal>
      <Reveal group class="method__grid">
        {
          method.map((step) => (
            <article class="method__step">
              <span class="method__n">{step.n}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))
        }
      </Reveal>
      <Reveal class="stack">
        <p class="stack__label">Supervised daily, across the whole stack:</p>
        <ul class="stack__list">
          {stack.map((tech) => <li>{tech}</li>)}
        </ul>
      </Reveal>
    </div>
  </section>

  <!-- Act 5 · Contact -->
  <section class="section contact">
    <div class="container--narrow contact__inner">
      <Reveal>
        <Image
          class="contact__portrait"
          src={portrait}
          alt="Thibaut Mottet"
          width={200}
          height={200}
        />
      </Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">If this way of working can be useful to your team, let's talk.</h2>
      </Reveal>
      <Reveal delay={0.1}>
        <p class="lede">
          I am looking for a senior role where this way of building can be applied to real
          problems.
        </p>
      </Reveal>
      <Reveal delay={0.2}>
        <div class="hero__actions contact__actions">
          <a class="btn btn--primary" href={`mailto:${site.email}`}>Get in touch</a>
          <a class="btn btn--ghost" href={site.github} rel="noopener">GitHub</a>
        </div>
      </Reveal>
    </div>
  </section>

  <SiteFooter />
</Base>

<style>
  .hero {
    display: grid;
    align-items: center;
    padding-block: clamp(2rem, 4vh, 3.25rem);
    position: relative;
    overflow: clip;
    background:
      radial-gradient(55% 45% at 88% 12%, rgba(48, 209, 88, 0.14) 0%, transparent 65%),
      radial-gradient(45% 40% at 8% 88%, rgba(114, 47, 55, 0.12) 0%, transparent 65%),
      var(--bg);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 22rem) 1fr;
    align-items: stretch;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  :global(.hero__card-wrap) {
    display: flex;
    min-width: 0;
  }

  .hero__right {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    min-width: 0;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    padding-top: clamp(0.5rem, 3vh, 2.5rem);
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__right {
      order: 2;
    }

    .hero__text {
      align-items: center;
      text-align: center;
    }

    :global(.hero__card-wrap) {
      order: 1;
      width: min(26rem, 100%);
      margin-inline: auto;
    }
  }

  .hero__lede {
    max-width: 40rem;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.7;
    color: var(--muted);
    text-wrap: pretty;
  }

  .hero :global(.display) {
    font-size: clamp(2rem, 3.4vw, 3.35rem);
    line-height: 1.08;
    text-wrap: balance;
  }

  .display__grad {
    background: linear-gradient(100deg, #1fa348 0%, #30d158 45%, #a4484f 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  @media (max-width: 820px) {
    .roles {
      justify-content: center;
    }
  }

  /* Profile card: light, clean, like a product card */
  .profile-card {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 1.6rem;
    border-radius: 1.5rem;
    color: var(--text);
    border: 1px solid var(--border);
    background: var(--card);
    box-shadow: 0 28px 56px -28px rgba(38, 34, 26, 0.22);
  }

  .profile-card__status {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.85rem;
    margin-bottom: 1.1rem;
    border-radius: 999px;
    background: rgba(48, 209, 88, 0.12);
    color: var(--green);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .profile-card__status-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }

  .profile-card__head {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  :global(.profile-card__avatar) {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 2px rgba(38, 34, 26, 0.08);
  }

  .profile-card__id {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.35;
  }

  .profile-card__id strong {
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
  }

  .profile-card__id span {
    font-size: 0.8438rem;
    color: var(--muted);
  }

  .profile-card__location {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .profile-card__location [data-icon] {
    width: 0.85em;
    height: 0.85em;
  }

  .profile-card__links {
    margin-left: auto;
    display: flex;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .profile-card__links a {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.65rem;
    border: 1px solid var(--border);
    color: var(--text);
    transition: background-color 0.2s;
  }

  .profile-card__links a:hover {
    background: rgba(38, 34, 26, 0.05);
  }

  .profile-card__links [data-icon] {
    width: 1rem;
    height: 1rem;
  }

  .profile-card__timeline {
    list-style: none;
    padding: 0;
    margin-top: 1.4rem;
    border-top: 1px solid var(--border);
    padding-top: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
  }

  .profile-card__timeline li {
    position: relative;
    padding-left: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .profile-card__timeline li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #c4bcab;
  }

  .profile-card__timeline li:first-child::before {
    background: var(--accent);
    box-shadow: 0 0 8px rgba(30, 125, 67, 0.45);
  }

  .profile-card__timeline li:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 3px;
    top: 1.1rem;
    bottom: -1.05rem;
    width: 1px;
    background: var(--border);
  }

  .profile-card__period {
    font-size: 0.7188rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .profile-card__timeline strong {
    font-size: 0.9063rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .profile-card__note {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  /* price + CTA, like a product card */
  .profile-card__offer {
    margin-top: auto;
    padding-top: 1.3rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .profile-card__price strong {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .profile-card__price span {
    font-size: 0.875rem;
    color: var(--muted);
    margin-left: 0.25rem;
  }

  .profile-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.65rem 1.2rem;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
  }

  .profile-card__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -8px rgba(30, 125, 67, 0.35);
  }

  .profile-card__cta [data-icon] {
    width: 1em;
    height: 1em;
  }

  .shift__headline {
    margin-block: 1rem 2.25rem;
  }

  /* :global — these classes land on component-rendered elements (Reveal/Image),
     which don't receive this page's scope hash */
  :global(.shift__copy) {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.7;
  }

  :global(.shift__copy) em {
    font-style: italic;
  }

  :global(.how__grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .how__card {
    padding: 2rem;
    border-top: 3px solid var(--accent);
  }

  .how__card:nth-child(2) {
    border-top-color: var(--bordeaux);
  }

  .how__card:nth-child(3) {
    border-top-color: var(--gold);
  }

  .how__card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }

  .how__card p {
    color: var(--muted);
    font-size: 1rem;
  }

  /* Method */
  :global(.method__grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .method__step {
    padding: 1.75rem;
    border-left: 2px solid var(--border);
  }

  .method__n {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.1em;
  }

  .method__step h3 {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-block: 0.6rem 0.5rem;
  }

  .method__step p {
    color: var(--muted);
    font-size: 0.9688rem;
    line-height: 1.6;
  }

  :global(.stack) {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stack__label {
    color: var(--muted);
    font-size: 0.9375rem;
  }

  .stack__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .stack__list li {
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 0.9375rem;
    font-weight: 550;
  }

  /* Proof: two cards filling the bottom of the hero right column */
  .proof__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  /* the Reveal wrapper around each card must stretch so both cards match height */
  .proof__grid > :global(*) {
    display: flex;
  }

  .proof-card {
    position: relative;
    display: block;
    flex: 1;
    min-height: 13rem;
    padding: 1.6rem;
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: transform 0.35s var(--ease-out), box-shadow 0.35s var(--ease-out);
    overflow: hidden;
  }

  @media (max-width: 560px) {
    .proof__grid {
      grid-template-columns: 1fr;
    }
  }

  .proof-card__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    height: 100%;
    max-width: 60%;
  }

  .proof-card__facts {
    list-style: none;
    padding: 0;
    margin-top: 0.55rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.875rem;
    opacity: 0.75;
  }

  .proof-card__facts strong {
    font-weight: 750;
  }

  .proof-card__phone {
    position: absolute;
    right: -3rem;
    top: 2.5rem;
    rotate: 8deg;
    pointer-events: none;
  }

  .proof-card__phone :global(.iphone) {
    --iphone-w: clamp(150px, 13vw, 195px);
  }

  @media (max-width: 640px) {
    .proof-card__body {
      max-width: 100%;
    }

    .proof-card__phone {
      position: static;
      rotate: 0deg;
      margin-top: 1.5rem;
      display: flex;
      justify-content: center;
    }

    .proof-card {
      min-height: 0;
    }
  }

  .proof-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 60px -24px rgba(0, 0, 0, 0.35);
  }

  .proof-card--crypto {
    background: radial-gradient(120% 120% at 80% 0%, #14231a 0%, #0a0a0f 55%);
    color: #f5f5f7;
    justify-content: center;
  }

  .proof-card__stat {
    font-size: clamp(2.75rem, 5vw, 4rem);
    font-weight: 850;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--green);
    font-variant-numeric: tabular-nums;
  }

  .proof-card__stat--sm {
    font-size: clamp(2.1rem, 3vw, 2.75rem);
    margin-top: 0.35rem;
  }

  .proof-card__sub {
    font-size: 0.9375rem;
    font-weight: 600;
