---
import { Image } from 'astro:assets'
import portrait from '../assets/portrait.jpg'
import appIcon from '../assets/vinarium/app-icon.png'
import cellarShot from '../assets/vinarium/cellar.png'
import dashboardShot from '../assets/vinarium/dashboard.png'
import scanReviewShot from '../assets/vinarium/scan-review.png'
import scanShot from '../assets/vinarium/scan.png'
import CryptoPhoneScreen from '../components/CryptoPhoneScreen.astro'
import PhoneCarousel from '../components/PhoneCarousel.astro'
import IPhoneFrame from '../components/IPhoneFrame.astro'
import Reveal from '../components/Reveal.astro'
import SiteFooter from '../components/SiteFooter.astro'
import StatCounter from '../components/StatCounter.astro'
import { cryptoBot, sinceLabel } from '../data/crypto-bot'
import { site } from '../data/site'
import Base from '../layouts/Base.astro'

const method = [
  {
    n: '01',
    title: 'Reach & user flow',
    text: 'How will the product reach its users? Wireframes to understand the user flow, before one line of code.',
  },
  {
    n: '02',
    title: 'First iteration',
    text: 'A first usable version, quickly, on a stack that is scalable and robust to change.',
  },
  {
    n: '03',
    title: 'Rails for the LLM',
    text: 'Domain-driven architecture, strong typing, data visualization, CI/CD. Everything that helps Claude deliver with almost no errors.',
  },
  {
    n: '04',
    title: 'Run & protect',
    text: 'Sentry watches bugs and performance permanently. The infrastructure rebuilds with one command. The application and the data stay secured.',
  },
]

const timeline = [
  {
    period: 'Since Jan. 2026',
    role: 'Paternity leave',
    note: 'shipping CryptoBot & Vinarium with Claude',
  },
  { period: '2018 · 2025', role: 'Freelance full-stack developer & lead tech', note: 'Paris' },
  { period: '2017 · 2018', role: 'CTO', note: 'pupscan.com' },
  { period: '2016 · 2017', role: 'Web developer', note: 'Société Générale' },
  { period: '2014 · 2016', role: 'CTO', note: 'alantaya.com' },
]

const stack = [
  'TypeScript',
  'Swift · SwiftUI',
  'GraphQL · Pothos',
  'Nitro · Bun',
  'Firebase · GCP',
  'Firestore',
  'Terraform',
  'Docker',
  'Claude API',
  'Gemini API',
]
---

<Base
  title="Thibaut Mottet · Senior full-stack developer, the impact of a whole team"
  description="AI is changing software development. I bring the method, the architecture and the product vision, Claude writes the code. Real products in production, used every day."
  theme="home"
>
  <!-- Act 1 · Hero -->
  <header class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <Reveal>
          <p class="eyebrow">{site.name} · {site.role} · {site.location}</p>
        </Reveal>
        <Reveal delay={0.08}>
          <h1 class="display">
            One senior developer.<br />The impact of a whole team.
          </h1>
        </Reveal>
        <Reveal delay={0.15}>
          <p class="lede hero__lede">
            AI is changing our job, let's not pretend otherwise. What it still lacks is method,
            architecture and product vision. That is what I bring. Claude writes the code.
          </p>
        </Reveal>
        <Reveal delay={0.2}>
          <div class="hero__actions">
            <a class="btn btn--primary" href={`mailto:${site.email}`}>Get in touch</a>
            <a class="btn btn--ghost" href={site.github} rel="noopener">GitHub</a>
          </div>
        </Reveal>
      </div>
      <Reveal delay={0.15} class="hero__portrait-wrap">
        <Image
          class="hero__portrait"
          src={portrait}
          alt="Portrait of Thibaut Mottet"
          width={460}
          height={460}
          loading="eager"
          fetchpriority="high"
        />
      </Reveal>
    </div>
  </header>

  <!-- Compact timeline -->
  <section class="timeline-strip">
    <div class="container">
      <Reveal group class="timeline">
        {
          timeline.map((t) => (
            <div class="timeline__item">
              <span class="timeline__period">{t.period}</span>
              <strong class="timeline__role">{t.role}</strong>
              <span class="timeline__note">{t.note}</span>
            </div>
          ))
        }
      </Reveal>
    </div>
  </section>

  <!-- Act 2 · The projects, first -->
  <section class="section proof" id="proof">
    <div class="container">
      <Reveal><p class="eyebrow">The proof</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">Two products I built this way,<br />and use every day.</h2>
      </Reveal>
      <div class="proof__grid">
        <Reveal>
          <a class="proof-card proof-card--crypto" href="/crypto-bot">
            <div class="proof-card__body">
              <p class="proof-card__eyebrow">CryptoBot · Grid trading, 24/7</p>
              <p class="proof-card__stat">
                <StatCounter value={cryptoBot.netPercent} decimals={2} prefix="+" suffix="%" />
              </p>
              <p class="proof-card__caption">
                net, on real money, while Bitcoin dropped {Math.abs(cryptoBot.holdPercent)}%
              </p>
              <ul class="proof-card__facts">
                <li><strong>+{cryptoBot.alphaVsHold} pts</strong> alpha vs HOLD</li>
                <li><strong>{cryptoBot.trades}</strong> trades since {sinceLabel}</li>
                <li><strong>{cryptoBot.cycleSeconds}s</strong> cycle on {cryptoBot.exchange}</li>
              </ul>
              <span class="proof-card__cta">See it work →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <CryptoPhoneScreen />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.1}>
          <a class="proof-card proof-card--vinarium" href="/vinarium">
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={appIcon}
                alt="Vinarium app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Vinarium · iOS</p>
              <p class="proof-card__title">A wine cellar that knows itself.</p>
              <p class="proof-card__caption">
                AI label scanning, live cellar value, drink windows.
              </p>
              <ul class="proof-card__facts">
                <li><strong>Claude</strong> reads the labels</li>
                <li><strong>Gemini</strong> estimates the price</li>
                <li><strong>SwiftUI</strong> native, iOS 26</li>
              </ul>
              <span class="proof-card__cta">Take the tour →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <PhoneCarousel
                  images={[
                    { src: dashboardShot, alt: 'Vinarium dashboard' },
                    { src: scanShot, alt: 'Scanning a wine label' },
                    { src: scanReviewShot, alt: 'AI-filled wine record' },
                    { src: cellarShot, alt: 'Cellar map' },
                  ]}
                />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Act 2 · The shift -->
  <section class="section">
    <div class="container--narrow">
      <Reveal><p class="eyebrow">The paradigm shift</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline shift__headline">
          AI is changing our profession. Let's not pretend otherwise.
        </h2>
      </Reveal>
      <Reveal group class="shift__copy">
        <p>
          Today, a senior developer with a good method can deliver what used to take a whole
          team. I see it every day: Claude writes excellent code, fast. The hard part has moved
          somewhere else.
        </p>
        <p>
          Because AI will not tell you to think about how to reach your customers, to draw
          wireframes to understand the user flow before coding, or to choose a stack that will
          survive three years of change. Product vision, methodology, architecture: this is where
          the human makes the difference. This is my job.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- Act 3 · How I work now -->
  <section class="section">
    <div class="container">
      <Reveal><p class="eyebrow">How I work now</p></Reveal>
      <Reveal delay={0.05}><h2 class="headline">What I bring</h2></Reveal>
      <Reveal group class="how__grid">
        <article class="card how__card">
          <h3>Product vision</h3>
          <p>
            How do we reach our customers? What is the user flow? Wireframes first, then a first
            iteration that real users can try. The code comes after the thinking.
          </p>
        </article>
        <article class="card how__card">
          <h3>Architecture that lasts</h3>
          <p>
            A stack that scales and accepts change: domain-driven boundaries, strong typing,
            CI/CD, an infrastructure easy to rebuild, the application and the data secured.
          </p>
        </article>
        <article class="card how__card">
          <h3>LLM supervision</h3>
          <p>
            Rails that help Claude deliver with the fewest errors possible: strict types, clear
            domains, code review on everything, and Sentry watching bugs and performance in
            production.
          </p>
        </article>
      </Reveal>
    </div>
  </section>

  <!-- Act 3b · The method, in practice -->
  <section class="section">
    <div class="container">
      <Reveal><p class="eyebrow">The method, in practice</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">From idea to production, every time</h2>
      </Reveal>
      <Reveal group class="method__grid">
        {
          method.map((step) => (
            <article class="method__step">
              <span class="method__n">{step.n}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))
        }
      </Reveal>
      <Reveal class="stack">
        <p class="stack__label">Supervised daily, across the whole stack:</p>
        <ul class="stack__list">
          {stack.map((tech) => <li>{tech}</li>)}
        </ul>
      </Reveal>
    </div>
  </section>

  <!-- Act 5 · Contact -->
  <section class="section contact">
    <div class="container--narrow contact__inner">
      <Reveal>
        <Image
          class="contact__portrait"
          src={portrait}
          alt="Thibaut Mottet"
          width={200}
          height={200}
        />
      </Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">If this way of working can be useful to your team, let's talk.</h2>
      </Reveal>
      <Reveal delay={0.1}>
        <p class="lede">
          I am looking for a senior role where this way of building can be applied to real
          problems.
        </p>
      </Reveal>
      <Reveal delay={0.2}>
        <div class="hero__actions contact__actions">
          <a class="btn btn--primary" href={`mailto:${site.email}`}>Get in touch</a>
          <a class="btn btn--ghost" href={site.github} rel="noopener">GitHub</a>
        </div>
      </Reveal>
    </div>
  </section>

  <SiteFooter />
</Base>

<style>
  .hero {
    min-height: 78svh;
    display: grid;
    align-items: center;
    padding-block: 4rem;
    position: relative;
    overflow: clip;
    background:
      radial-gradient(55% 45% at 88% 12%, rgba(48, 209, 88, 0.09) 0%, transparent 65%),
      radial-gradient(45% 40% at 8% 88%, rgba(114, 47, 55, 0.09) 0%, transparent 65%),
      var(--bg);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.75rem;
  }

  :global(.hero__portrait-wrap) {
    justify-self: center;
  }

  :global(.hero__portrait) {
    width: clamp(14rem, 26vw, 22rem);
    height: auto;
    border-radius: 2rem;
    box-shadow: 0 40px 80px -30px rgba(22, 24, 29, 0.4);
    rotate: 2deg;
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .hero__text {
      align-items: center;
      order: 2;
    }

    :global(.hero__portrait-wrap) {
      order: 1;
    }

    :global(.hero__portrait) {
      width: 11rem;
      border-radius: 1.5rem;
    }
  }

  .hero__lede {
    max-width: 38rem;
  }

  /* Compact timeline strip */
  .timeline-strip {
    border-block: 1px solid var(--border);
    padding-block: 2rem;
    background: var(--card);
  }

  :global(.timeline) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 1.5rem;
  }

  .timeline__item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
    position: relative;
  }

  .timeline__item::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 0.45rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--muted);
  }

  .timeline__item:first-child {
    border-left-color: var(--green);
  }

  .timeline__item:first-child::before {
    background: var(--green);
  }

  .timeline__period {
    font-size: 0.8125rem;
    font-weight: 650;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .timeline__role {
    font-size: 0.9688rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .timeline__note {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .hero__actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .shift__headline {
    margin-block: 1rem 2.25rem;
  }

  /* :global — these classes land on component-rendered elements (Reveal/Image),
     which don't receive this page's scope hash */
  :global(.shift__copy) {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.7;
  }

  :global(.shift__copy) em {
    font-style: italic;
  }

  :global(.how__grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .how__card {
    padding: 2rem;
  }

  .how__card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }

  .how__card p {
    color: var(--muted);
    font-size: 1rem;
  }

  /* Method */
  :global(.method__grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .method__step {
    padding: 1.75rem;
    border-left: 2px solid var(--border);
  }

  .method__n {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .method__step h3 {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-block: 0.6rem 0.5rem;
  }

  .method__step p {
    color: var(--muted);
    font-size: 0.9688rem;
    line-height: 1.6;
  }

  :global(.stack) {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stack__label {
    color: var(--muted);
    font-size: 0.9375rem;
  }

  .stack__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .stack__list li {
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 0.9375rem;
    font-weight: 550;
  }

  /* Proof */
  .proof__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .proof-card {
    position: relative;
    display: block;
    min-height: 28rem;
    padding: 2.25rem;
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: transform 0.35s var(--ease-out), box-shadow 0.35s var(--ease-out);
    overflow: hidden;
  }

  .proof-card__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    height: 100%;
    max-width: 62%;
  }

  .proof-card__facts {
    list-style: none;
    padding: 0;
    margin-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.9375rem;
    opacity: 0.75;
  }

  .proof-card__facts strong {
    font-weight: 750;
  }

  .proof-card__phone {
    position: absolute;
    right: -3.5rem;
    top: 3.5rem;
    rotate: 8deg;
    pointer-events: none;
  }

  .proof-card__phone :global(.iphone) {
    --iphone-w: clamp(180px, 16vw, 230px);
  }

  @media (max-width: 640px) {
    .proof-card__body {
      max-width: 100%;
    }

    .proof-card__phone {
      position: static;
      rotate: 0deg;
      margin-top: 1.5rem;
      display: flex;
      justify-content: center;
    }

    .proof-card {
      min-height: 0;
    }
  }

  .proof-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 60px -24px rgba(0, 0, 0, 0.35);
  }

  .proof-card--crypto {
    background: radial-gradient(120% 120% at 80% 0%, #14231a 0%, #0a0a0f 55%);
    color: #f5f5f7;
    justify-content: center;
  }

  .proof-card__stat {
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 850;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--green);
    font-variant-numeric: tabular-nums;
  }

  .proof-card--vinarium {
    background: radial-gradient(120% 120% at 20% 0%, #2c1a22 0%, #181114 60%);
    color: #f6efe7;
    justify-content: center;
  }

  :global(.proof-card__icon) {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 1.05rem;
    box-shadow: 0 10px 24px -8px rgba(0, 0, 0, 0.5);
    margin-bottom: 0.5rem;
  }

  .proof-card__eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .proof-card__title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 750;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .proof-card__caption {
    opacity: 0.65;
    font-size: 1rem;
  }

  .proof-card__cta {
    margin-top: auto;
    padding-top: 1.5rem;
    font-weight: 650;
  }

  .contact__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  :global(.contact__portrait) {
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 16px 32px -12px rgba(22, 24, 29, 0.35);
  }
</style>
