<script>
  // Project card filtering by category. Multiple filters can be active at once
  // (a card shows if it matches any of them); with none active the "All" button
  // lights up. The selection is mirrored to a shareable ?filter=a,b URL param.
  const buttons = document.querySelectorAll<HTMLButtonElement>('.proof__filter')
  const cards = document.querySelectorAll<HTMLElement>('.proof-card[data-category]')
  const knownKeys = new Set(
    [...buttons].map((b) => b.dataset['filter']).filter((k): k is string => !!k && k !== 'all'),
  )
  const active = new Set<string>()

  const render = () => {
    const showAll = active.size === 0
    for (const b of buttons) {
      const key = b.dataset['filter'] ?? ''
      b.classList.toggle('is-active', key === 'all' ? showAll : active.has(key))
    }
    for (const card of cards) {
      const wrapper = (card.parentElement ?? card) as HTMLElement
      const categories = (card.dataset['category'] ?? '').split(' ')
      const match = showAll || categories.some((c) => active.has(c))
      wrapper.style.display = match ? '' : 'none'
    }
    const url = new URL(window.location.href)
    if (active.size === 0) url.searchParams.delete('filter')
    else url.searchParams.set('filter', [...active].join(','))
    // keep the comma literal so shared links read ?filter=hardware,ios
    window.history.replaceState(null, '', url.href.replace(/%2C/g, ','))
  }

  for (const button of buttons) {
    button.addEventListener('click', () => {
      const key = button.dataset['filter'] ?? 'all'
      if (key === 'all') active.clear()
      else if (active.has(key)) active.delete(key)
      else active.add(key)
      render()
    })
  }

  // Activate the filters requested in the URL (e.g. ?filter=hardware,ios) on load
  const requested = new URLSearchParams(window.location.search).get('filter')
  if (requested) {
    for (const key of requested.split(',')) if (knownKeys.has(key)) active.add(key)
  }
  render()
</script>

