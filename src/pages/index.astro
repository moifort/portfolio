---
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import portrait from '../assets/portrait.jpg'
import appIcon from '../assets/vinarium/app-icon.png'
import cellarShot from '../assets/vinarium/cellar.png'
import dashboardShot from '../assets/vinarium/dashboard.png'
import scanReviewShot from '../assets/vinarium/scan-review.png'
import CryptoPhoneScreen from '../components/CryptoPhoneScreen.astro'
import PhoneCarousel from '../components/PhoneCarousel.astro'
import IPhoneFrame from '../components/IPhoneFrame.astro'
import Reveal from '../components/Reveal.astro'
import StatCounter from '../components/StatCounter.astro'
import cryptoIcon from '../assets/crypto-bot/app-icon.png'
import statsIcon from '../assets/stats/app-icon.png'
import { cryptoBot, sinceLabel } from '../data/crypto-bot'
import { site } from '../data/site'
import Base from '../layouts/Base.astro'

const roles = [
  { icon: 'lucide:pen-tool', label: 'UI/UX' },
  { icon: 'lucide:monitor', label: 'Frontend' },
  { icon: 'lucide:server', label: 'Backend' },
  { icon: 'lucide:terminal', label: 'Ops' },
  { icon: 'lucide:shield', label: 'Security' },
  { icon: 'lucide:database', label: 'Data' },
]

const timeline = [
  {
    period: 'Since Jan. 2026',
    role: 'Paternity leave',
    note: 'shipping CryptoBot & Vinarium with Claude',
  },
  {
    period: '2018 · 2025',
    role: 'Freelance full-stack developer & lead tech',
    note: 'remote, abroad',
  },
  { period: '2017 · 2018', role: 'CTO', note: 'pupscan.com' },
  { period: '2016 · 2017', role: 'Web developer', note: 'Société Générale' },
  { period: '2014 · 2016', role: 'CTO', note: 'alantaya.com' },
]
---

<Base
  title="Thibaut Mottet · Senior full-stack developer, the impact of a whole team"
  description="AI is changing software development. I bring the method, the architecture and the product vision, Claude writes the code. Real products in production, used every day."
  theme="home"
>
  <!-- Act 1 · Hero -->
  <header class="hero">
    <div class="container hero__inner">
      <Reveal delay={0.15} class="hero__card-wrap">
        <aside class="profile-card">
          <span class="profile-card__status">
            <span class="profile-card__status-dot"></span>
            Open to new missions
          </span>
          <div class="profile-card__head">
            <Image
              class="profile-card__avatar"
              src={portrait}
              alt="Portrait of Thibaut Mottet"
              width={160}
              height={160}
              loading="eager"
              fetchpriority="high"
            />
            <div class="profile-card__id">
              <strong>{site.name}</strong>
              <span>{site.role}</span>
              <span class="profile-card__location">
                <Icon name="lucide:map-pin" />
                {site.location}
              </span>
            </div>
            <div class="profile-card__links">
              <a href={site.github} rel="noopener" aria-label="GitHub">
                <Icon name="lucide:github" />
              </a>
              <a href={`mailto:${site.email}`} aria-label="Email">
                <Icon name="lucide:mail" />
              </a>
            </div>
          </div>
          <ol class="profile-card__timeline">
            {
              timeline.map((t) => (
                <li>
                  <span class="profile-card__period">{t.period}</span>
                  <strong>{t.role}</strong>
                  <span class="profile-card__note">{t.note}</span>
                </li>
              ))
            }
          </ol>
          <div class="profile-card__offer">
            <p class="profile-card__price">
              <strong>{site.dailyRate}&nbsp;€</strong><span>/ day</span>
            </p>
            <a class="profile-card__cta" href={`mailto:${site.email}`}>
              Hire me <Icon name="lucide:arrow-right" />
            </a>
          </div>
        </aside>
        <a class="mini-card" href="https://github.com/moifort/minimal-stats" rel="noopener">
          <Image class="mini-card__icon" src={statsIcon} alt="Stats app icon" width={200} height={200} />
          <span class="mini-card__text">
            <span class="mini-card__title">Stats · macOS</span>
            <span class="mini-card__sub">System metrics in your menu bar</span>
          </span>
          <Icon name="lucide:arrow-up-right" />
        </a>
      </Reveal>
      <div class="hero__right">
        <div class="hero__text">
          <Reveal delay={0.08}>
            <h1 class="display">
              One senior developer.<br />The impact of a <span class="display__grad"
                >whole team</span
              >.
            </h1>
          </Reveal>
          <Reveal delay={0.15}>
            <p class="hero__lede">
              AI is changing our job, let's not pretend otherwise. What it still lacks is method,
              architecture and product vision. On my own, I now have a full team at my disposal:
            </p>
          </Reveal>
          <Reveal delay={0.2}>
            <ul class="hero__roles" aria-label="Roles I cover">
              {
                roles.map((r) => (
                  <li class="hero__role">
                    <Icon name={r.icon} />
                    {r.label}
                  </li>
                ))
              }
            </ul>
          </Reveal>
        </div>
        <div class="proof__grid" id="proof">
          <Reveal>
          <a class="proof-card proof-card--crypto" href="/crypto-bot">
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={cryptoIcon}
                alt="CryptoBot app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">CryptoBot · iOS</p>
              <p class="proof-card__stat proof-card__stat--sm">
                <StatCounter value={cryptoBot.netPercent} decimals={2} prefix="+" suffix="%" />
              </p>
              <p class="proof-card__caption">net since {sinceLabel} · Grid trading, 24/7</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <CryptoPhoneScreen />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.1}>
          <a class="proof-card proof-card--vinarium" href="/vinarium">
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={appIcon}
                alt="Vinarium app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Vinarium · iOS</p>
              <p class="proof-card__title">Manage your wine cellar.</p>
              <p class="proof-card__caption">AI, location, price, sharing and more.</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <PhoneCarousel
                  images={[
                    { src: dashboardShot, alt: 'Vinarium dashboard' },
                    { src: scanReviewShot, alt: 'AI-filled wine record' },
                    { src: cellarShot, alt: 'Cellar map' },
                  ]}
                />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        </div>
      </div>
    </div>
  </header>
</Base>

<style>
  .hero {
    display: grid;
    align-items: center;
    min-height: 100svh;
    padding-block: clamp(2rem, 5vh, 4rem);
    position: relative;
    overflow: clip;
    background:
      radial-gradient(55% 45% at 88% 12%, rgba(48, 209, 88, 0.14) 0%, transparent 65%),
      radial-gradient(45% 40% at 8% 88%, rgba(114, 47, 55, 0.12) 0%, transparent 65%),
      var(--bg);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 22rem) 1fr;
    align-items: stretch;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  :global(.hero__card-wrap) {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  .profile-card {
    flex: 1;
  }

  /* compact card under the profile card */
  .mini-card {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1rem 1.15rem;
    border-radius: 1.25rem;
    border: 1px solid var(--border);
    background: var(--card);
    box-shadow: 0 20px 40px -28px rgba(38, 34, 26, 0.22);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .mini-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 26px 48px -26px rgba(38, 34, 26, 0.3);
  }

  :global(.mini-card__icon) {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.7rem;
    flex-shrink: 0;
    box-shadow: 0 6px 14px -6px rgba(0, 0, 0, 0.4);
  }

  .mini-card__text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .mini-card__title {
    font-weight: 700;
    font-size: 0.9688rem;
    letter-spacing: -0.01em;
  }

  .mini-card__sub {
    font-size: 0.8438rem;
    color: var(--muted);
  }

  .mini-card :global([data-icon]) {
    margin-left: auto;
    width: 1.1rem;
    height: 1.1rem;
    color: var(--muted);
    flex-shrink: 0;
  }

  .hero__right {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    min-width: 0;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    padding-top: clamp(0.5rem, 3vh, 2.5rem);
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__right {
      order: 2;
    }

    .hero__text {
      align-items: center;
      text-align: center;
    }

    :global(.hero__card-wrap) {
      order: 1;
      width: min(26rem, 100%);
      margin-inline: auto;
    }
  }

  .hero__lede {
    max-width: 40rem;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.7;
    color: var(--text);
    text-wrap: pretty;
  }

  .hero__roles {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .hero__role {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .hero__role [data-icon] {
    width: 1em;
    height: 1em;
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .hero__roles {
      justify-content: center;
    }
  }

  .hero :global(.display) {
    font-size: clamp(2rem, 3.4vw, 3.35rem);
    line-height: 1.08;
    text-wrap: balance;
  }

  .display__grad {
    background: linear-gradient(100deg, #1fa348 0%, #30d158 45%, #a4484f 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  @media (max-width: 820px) {
    .roles {
      justify-content: center;
    }
  }

  /* Profile card: light, clean, like a product card */
  .profile-card {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 1.6rem;
    border-radius: 1.5rem;
    color: var(--text);
    border: 1px solid var(--border);
    background: var(--card);
    box-shadow: 0 28px 56px -28px rgba(38, 34, 26, 0.22);
  }

  .profile-card__status {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.85rem;
    margin-bottom: 1.1rem;
    border-radius: 999px;
    background: rgba(48, 209, 88, 0.12);
    color: var(--green);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .profile-card__status-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }

  .profile-card__head {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  :global(.profile-card__avatar) {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 2px rgba(38, 34, 26, 0.08);
  }

  .profile-card__id {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.35;
  }

  .profile-card__id strong {
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
  }

  .profile-card__id span {
    font-size: 0.8438rem;
    color: var(--muted);
  }

  .profile-card__location {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .profile-card__location [data-icon] {
    width: 0.85em;
    height: 0.85em;
  }

  .profile-card__links {
    margin-left: auto;
    display: flex;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .profile-card__links a {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.65rem;
    border: 1px solid var(--border);
    color: var(--text);
    transition: background-color 0.2s;
  }

  .profile-card__links a:hover {
    background: rgba(38, 34, 26, 0.05);
  }

  .profile-card__links [data-icon] {
    width: 1rem;
    height: 1rem;
  }

  .profile-card__timeline {
    list-style: none;
    padding: 0;
    margin-top: 1.4rem;
    border-top: 1px solid var(--border);
    padding-top: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
  }

  .profile-card__timeline li {
    position: relative;
    padding-left: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .profile-card__timeline li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #c4bcab;
  }

  .profile-card__timeline li:first-child::before {
    background: var(--accent);
    box-shadow: 0 0 8px rgba(30, 125, 67, 0.45);
  }

  .profile-card__timeline li:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 3px;
    top: 1.1rem;
    bottom: -1.05rem;
    width: 1px;
    background: var(--border);
  }

  .profile-card__period {
    font-size: 0.7188rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .profile-card__timeline strong {
    font-size: 0.9063rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .profile-card__note {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  /* price + CTA, like a product card */
  .profile-card__offer {
    margin-top: auto;
    padding-top: 1.3rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .profile-card__price strong {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .profile-card__price span {
    font-size: 0.875rem;
    color: var(--muted);
    margin-left: 0.25rem;
  }

  .profile-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.65rem 1.2rem;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
  }

  .profile-card__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -8px rgba(30, 125, 67, 0.35);
  }

  .profile-card__cta [data-icon] {
    width: 1em;
    height: 1em;
  }

  .shift__headline {
    margin-block: 1rem 2.25rem;
  }

  /* :global — these classes land on component-rendered elements (Reveal/Image),
     which don't receive this page's scope hash */
  :global(.shift__copy) {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.7;
  }

  :global(.shift__copy) em {
    font-style: italic;
  }

  :global(.how__grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .how__card {
    padding: 2rem;
    border-top: 3px solid var(--accent);
  }

  .how__card:nth-child(2) {
    border-top-color: var(--bordeaux);
  }

  .how__card:nth-child(3) {
    border-top-color: var(--gold);
  }

  .how__card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }

  .how__card p {
    color: var(--muted);
    font-size: 1rem;
  }

  /* Method */
  :global(.method__grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .method__step {
    padding: 1.75rem;
    border-left: 2px solid var(--border);
  }

  .method__n {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.1em;
  }

  .method__step h3 {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-block: 0.6rem 0.5rem;
  }

  .method__step p {
    color: var(--muted);
    font-size: 0.9688rem;
    line-height: 1.6;
  }

  :global(.stack) {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stack__label {
    color: var(--muted);
    font-size: 0.9375rem;
  }

  .stack__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .stack__list li {
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 0.9375rem;
    font-weight: 550;
  }

  /* Proof: two cards filling the bottom of the hero right column */
  .proof__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  /* the Reveal wrapper around each card must stretch so both cards match height */
  .proof__grid > :global(*) {
    display: flex;
  }

  .proof-card {
    position: relative;
    display: block;
    flex: 1;
    min-height: 13rem;
    padding: 1.6rem;
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: transform 0.35s var(--ease-out), box-shadow 0.35s var(--ease-out);
    overflow: hidden;
  }

  @media (max-width: 560px) {
    .proof__grid {
      grid-template-columns: 1fr;
    }
  }

  .proof-card__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    height: 100%;
    max-width: 60%;
  }

  .proof-card__facts {
    list-style: none;
    padding: 0;
    margin-top: 0.55rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.875rem;
    opacity: 0.75;
  }

  .proof-card__facts strong {
    font-weight: 750;
  }

  .proof-card__phone {
    position: absolute;
    right: -3rem;
    top: 2.5rem;
    rotate: 8deg;
    pointer-events: none;
  }

  .proof-card__phone :global(.iphone) {
    --iphone-w: clamp(150px, 13vw, 195px);
  }

  @media (max-width: 640px) {
    .proof-card__body {
      max-width: 100%;
    }

    .proof-card__phone {
      position: static;
      rotate: 0deg;
      margin-top: 1.5rem;
      display: flex;
      justify-content: center;
    }

    .proof-card {
      min-height: 0;
    }
  }

  .proof-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 60px -24px rgba(0, 0, 0, 0.35);
  }

  .proof-card--crypto {
    background: radial-gradient(120% 120% at 80% 0%, #14231a 0%, #0a0a0f 55%);
    color: #f5f5f7;
    justify-content: center;
  }

  .proof-card__stat {
    font-size: clamp(2.75rem, 5vw, 4rem);
    font-weight: 850;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--green);
    font-variant-numeric: tabular-nums;
  }

  .proof-card__stat--sm {
    font-size: clamp(2.1rem, 3vw, 2.75rem);
    margin-top: 0.35rem;
  }

  .proof-card--vinarium {
    background: radial-gradient(120% 120% at 20% 0%, #2c1a22 0%, #181114 60%);
    color: #f6efe7;
    justify-content: center;
  }

  :global(.proof-card__icon) {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 0.85rem;
    box-shadow: 0 10px 24px -8px rgba(0, 0, 0, 0.5);
    margin-bottom: 0.35rem;
  }

  .proof-card__eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .proof-card__title {
    font-size: clamp(1.4rem, 2.4vw, 1.85rem);
    font-weight: 750;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .proof-card__caption {
    opacity: 0.65;
    font-size: 0.9375rem;
  }

  .proof-card__cta {
    margin-top: auto;
    padding-top: 1.1rem;
    font-weight: 650;
    font-size: 0.9375rem;
  }

  .contact__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  :global(.contact__portrait) {
    width: 5.5rem;
