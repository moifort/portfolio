---
import type { ImageMetadata } from 'astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import arnaudImg from '../assets/influences/arnaud-lemaire.jpg'
import cyrilImg from '../assets/influences/cyril-martraire.jpg'
import davidImg from '../assets/influences/david-gageot.jpg'
import evansImg from '../assets/influences/eric-evans.jpg'
import fowlerImg from '../assets/influences/martin-fowler.jpg'
import jeremieImg from '../assets/influences/jeremie-chassaing.jpg'
import mancusoImg from '../assets/influences/sandro-mancuso.jpg'
import mattImg from '../assets/influences/matt-pocock.jpg'
import robertImg from '../assets/influences/robert-martin.jpg'
import scottImg from '../assets/influences/scott-wlaschin.jpg'
import theoImg from '../assets/influences/theo.jpg'
import portrait from '../assets/portrait.jpg'
import appIcon from '../assets/vinarium/app-icon.png'
import cellarShot from '../assets/vinarium/cellar.png'
import dashboardShot from '../assets/vinarium/dashboard.png'
import scanReviewShot from '../assets/vinarium/scan-review.png'
import CryptoPhoneScreen from '../components/CryptoPhoneScreen.astro'
import PhoneCarousel from '../components/PhoneCarousel.astro'
import IPhoneFrame from '../components/IPhoneFrame.astro'
import ModelViewer from '../components/ModelViewer.astro'
import Reveal from '../components/Reveal.astro'
import StatCounter from '../components/StatCounter.astro'
import bazarIcon from '../assets/bazar/app-icon.png'
import carnetIcon from '../assets/carnet/app-icon.png'
import carnetHome from '../assets/carnet/home.png'
import carnetRecipe from '../assets/carnet/recipe.png'
import carnetProposal from '../assets/carnet/proposal.png'
import gridfinityIcon from '../assets/gridfinity/app-icon.png'
import lerobotIcon from '../assets/lerobot/app-icon.png'
import orbIcon from '../assets/orb/app-icon.png'
import orbMachine from '../assets/orb/machine.png'
import bloomin8Logo from '../assets/bloomin8/logo.png'
import bloomin8Screen from '../assets/bloomin8/app-screen.png'
import cryptoIcon from '../assets/crypto-bot/app-icon.png'
import homeIcon from '../assets/homebridge-fan/apple-home-icon.jpg'
import alantayaLogo from '../assets/logos/alantaya.png'
import decathlonLogo from '../assets/logos/decathlon.png'
import pupscanLogo from '../assets/logos/pupscan.png'
import societeGeneraleLogo from '../assets/logos/societegenerale.png'
import sundayLogo from '../assets/logos/sunday.png'
import homeFanScreen from '../assets/homebridge-fan/app-screen.png'
import statsIcon from '../assets/stats/app-icon.png'
import statsPopover from '../assets/stats/popover.png'
import { cryptoBot, sinceLabel } from '../data/crypto-bot'
import { site } from '../data/site'
import Base from '../layouts/Base.astro'

const roles = [
  { icon: 'lucide:pen-tool', label: 'UI/UX', color: '#d6336c' },
  { icon: 'lucide:monitor', label: 'Frontend', color: '#1c7ed6' },
  { icon: 'lucide:server', label: 'Backend', color: '#2f9e44' },
  { icon: 'lucide:terminal', label: 'Ops', color: '#e8930c' },
  { icon: 'lucide:shield', label: 'Security', color: '#e03131' },
  { icon: 'lucide:database', label: 'Data', color: '#4263eb' },
  { icon: 'lucide:bug', label: 'QA', color: '#9c36b5' },
]

const filters = [
  { key: 'all', label: 'All', icon: 'lucide:layout-grid' },
  { key: 'ios', label: 'iOS', icon: 'lucide:smartphone' },
  { key: 'macos', label: 'macOS', icon: 'lucide:laptop' },
  { key: 'home-automation', label: 'Home automation', icon: 'lucide:house' },
  { key: 'hardware', label: 'Hardware', icon: 'lucide:cpu' },
  { key: 'robotics', label: 'Robotics', icon: 'lucide:bot' },
  { key: 'library', label: 'Library', icon: 'lucide:package' },
  { key: '3d-printing', label: '3D printing', icon: 'lucide:box' },
  { key: 'utility', label: 'Utility', icon: 'lucide:wrench' },
]

const toolbox = [
  'Craftsmanship',
  'DDD',
  'CQRS',
  'Event Sourcing',
  'Functional Programming',
  'Atomic Design',
  'Firebase (Firestore, Hosting, Functions…)',
  'Docker',
  'Infra as Code',
  'CI/CD',
]

type Influence = {
  name: string
  url: string
  img?: ImageMetadata
  mono?: string
  emoji?: string
  items: { icon: string; label: string }[]
}

const influences: Influence[] = [
  {
    name: 'Scott Wlaschin',
    emoji: '😍',
    url: 'https://fsharpforfunandprofit.com',
    img: scottImg,
    items: [{ icon: 'lucide:book-open', label: 'Domain Modeling Made Functional' }],
  },
  {
    name: 'Eric Evans',
    url: 'https://www.domainlanguage.com',
    img: evansImg,
    items: [{ icon: 'lucide:book-open', label: 'Domain-Driven Design' }],
  },
  {
    name: 'Martin Fowler',
    url: 'https://martinfowler.com',
    img: fowlerImg,
    items: [
      { icon: 'lucide:book-open', label: 'Refactoring' },
      { icon: 'lucide:youtube', label: 'Conference talks' },
    ],
  },
  {
    name: 'Robert C. Martin',
    url: 'https://blog.cleancoder.com',
    img: robertImg,
    items: [{ icon: 'lucide:book-open', label: 'Clean Code' }],
  },
  {
    name: 'Sandro Mancuso',
    url: 'https://www.codurance.com',
    img: mancusoImg,
    items: [{ icon: 'lucide:book-open', label: 'The Software Craftsman' }],
  },
  {
    name: 'Cyril Martraire',
    url: 'https://www.livingdocumentation.net',
    img: cyrilImg,
    items: [{ icon: 'lucide:book-open', label: 'Living Documentation' }],
  },
  {
    name: 'Arnaud Lemaire',
    url: 'https://www.youtube.com/results?search_query=arnaud+lemaire+ddd',
    img: arnaudImg,
    items: [{ icon: 'lucide:mic', label: 'Talks' }],
  },
  {
    name: 'Jérémie Chassaing',
    url: 'https://www.youtube.com/results?search_query=jérémie+chassaing',
    img: jeremieImg,
    items: [{ icon: 'lucide:mic', label: 'Talks' }],
  },
  {
    name: 'David Gageot',
    url: 'https://www.youtube.com/results?search_query=david+gageot',
    img: davidImg,
    items: [{ icon: 'lucide:mic', label: 'Talks' }],
  },
  {
    name: 'Theo (T3)',
    url: 'https://www.youtube.com/@t3dotgg',
    img: theoImg,
    items: [{ icon: 'lucide:youtube', label: 'YouTube channel' }],
  },
  {
    name: 'Matt Pocock',
    url: 'https://www.youtube.com/@mattpocockuk',
    img: mattImg,
    items: [{ icon: 'lucide:youtube', label: 'YouTube channel' }],
  },
]

const timeline: {
  period: string
  role: string
  note: string
  current?: boolean
  logo?: ImageMetadata
}[] = [
  {
    period: 'Since Jan. 2026',
    role: 'Paternity leave',
    note: 'shipping product after product with Claude Opus & Fable',
    current: true,
  },
  {
    period: 'Jul. 2025 → Jan. 2026',
    role: 'Senior developer',
    note: 'Sunday',
    logo: sundayLogo,
  },
  {
    period: '2020 → 2025',
    role: 'Freelance full-stack developer & tech lead',
    note: 'remote, abroad',
  },
  { period: '2018 → 2020', role: 'Tech lead', note: 'Decathlon', logo: decathlonLogo },
  { period: '2017 → 2018', role: 'CTO', note: 'pupscan.com', logo: pupscanLogo },
  {
    period: '2016 → 2017',
    role: 'Web developer',
    note: 'Société Générale',
    logo: societeGeneraleLogo,
  },
  { period: '2014 → 2016', role: 'CTO', note: 'alantaya.com', logo: alantayaLogo },
]
---

<Base
  title="Thibaut Mottet · Senior full-stack developer, the impact of a whole team"
  description="AI is changing software development. I bring the method, the architecture and the product vision, Claude writes the code. Real products in production, used every day."
  theme="home"
>
  <!-- Act 1 · Hero -->
  <header class="hero">
    <div class="container hero__inner">
      <div class="hero__top">
      <Reveal delay={0.15} class="hero__card-wrap">
        <aside class="profile-card">
          <span class="profile-card__status">
            <span class="profile-card__status-dot"></span>
            Open to new missions
          </span>
          <div class="profile-card__head">
            <Image
              class="profile-card__avatar"
              src={portrait}
              alt="Portrait of Thibaut Mottet"
              width={160}
              height={160}
              loading="eager"
              fetchpriority="high"
            />
            <div class="profile-card__id">
              <strong>{site.name}</strong>
              <span>{site.role}</span>
              <span class="profile-card__location">
                <Icon name="lucide:map-pin" />
                {site.location}
              </span>
            </div>
            <div class="profile-card__links">
              <a href={site.github} rel="noopener" aria-label="GitHub">
                <Icon name="lucide:github" />
              </a>
              <a href={`mailto:${site.email}`} aria-label="Email">
                <Icon name="lucide:mail" />
              </a>
            </div>
          </div>
          <ol class="profile-card__timeline">
            {
              timeline.map((t) => (
                <li class:list={['tl-entry', { 'is-current': t.current }]}>
                  <span class="profile-card__period">{t.period}</span>
                  <strong>{t.role}</strong>
                  <span class="profile-card__note">
                    {t.logo && <Image src={t.logo} alt="" width={36} height={36} class="tl-logo" />}
                    {t.note}
                  </span>
                </li>
              ))
            }
            <li class="tl-gap" aria-hidden="true">
              <span>a lot happened…</span>
            </li>
            <li class="tl-birth">
              <span class="profile-card__period">1985</span>
              <strong class="tl-baby">👶</strong>
            </li>
          </ol>
          <div class="profile-card__offer">
            <p class="profile-card__price">
              <strong>{site.dailyRate}&nbsp;€</strong><span>/ day</span>
            </p>
            <a class="profile-card__cta" href={`mailto:${site.email}`}>
              Hire me <Icon name="lucide:arrow-right" />
            </a>
          </div>
        </aside>
        <aside class="influences-card">
          <p class="influences-card__eyebrow">Influences</p>
          <ul class="influences-card__list">
            {
              influences.map((person) => (
                <li class="influences-card__row">
                  {person.img ? (
                    <Image
                      class="influences-card__avatar"
                      src={person.img}
                      alt={`Portrait of ${person.name}`}
                      width={120}
                      height={120}
                    />
                  ) : (
                    <span class="influences-card__avatar influences-card__mono">{person.mono}</span>
                  )}
                  <div class="influences-card__info">
                    <a href={person.url} rel="noopener">
                      {person.name}
                      {person.emoji && <span class="influences-card__emoji">{person.emoji}</span>}
                    </a>
                    <ul class="influences-card__items">
                      {
                        person.items.map((item) => (
                          <li>
                            <Icon name={item.icon} />
                            {item.label}
                          </li>
                        ))
                      }
                    </ul>
                  </div>
                </li>
              ))
            }
          </ul>
        </aside>
        <aside class="influences-card toolbox-card">
          <p class="influences-card__eyebrow">Toolbox</p>
          <ul class="toolbox-card__list">
            {toolbox.map((tool) => <li>{tool}</li>)}
          </ul>
        </aside>
      </Reveal>
      <div class="hero__right">
        <div class="hero__text">
          <Reveal delay={0.08}>
            <h1 class="display">
              One senior developer with the impact of a <span class="display__grad"
                >whole team</span
              >.
            </h1>
          </Reveal>
          <Reveal delay={0.15} class="hero__pitch">
            <p class="hero__lede">
              AI is changing our job, let's not pretend otherwise. What it still lacks is method,
              architecture and product vision. On my own, I now have a full team at my disposal:
              {' '}
              {
                roles.map((r) => (
                  <span class="inline-badge" style={`--c:${r.color}`}>
                    <Icon name={r.icon} />
                    {r.label}
                  </span>
                ))
              }
              {' '}
              With them behind me, I build like never before, 10 to 30× faster, and finally
              ship high quality products all the way to production.
            </p>
          </Reveal>
        </div>
        <Reveal delay={0.25} class="hero__filters">
          <div class="proof__filters" role="group" aria-label="Filter projects">
            {
              filters.map((f) => (
                <button
                  class:list={['proof__filter', { 'is-active': f.key === 'all' }]}
                  data-filter={f.key}
                >
                  <Icon name={f.icon} />
                  {f.label}
                </button>
              ))
            }
          </div>
        </Reveal>
        <div class="proof__grid" id="proof">
          <Reveal>
          <a class="proof-card proof-card--crypto" href="/crypto-bot" data-category="ios">
            <span class="proof-card__date">Feb 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={cryptoIcon}
                alt="CryptoBot app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">CryptoBot · iOS</p>
              <p class="proof-card__stat proof-card__stat--sm">
                <StatCounter value={cryptoBot.netPercent} decimals={2} prefix="▲ " suffix="%" />
              </p>
              <p class="proof-card__caption">
                net since {sinceLabel} · holding BTC:
                <span class="hold-down">▼&nbsp;{Math.abs(cryptoBot.holdPercent)}%</span>
              </p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <CryptoPhoneScreen />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.1}>
          <a class="proof-card proof-card--vinarium" href="/vinarium" data-category="ios">
            <span class="proof-card__date">Jan 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={appIcon}
                alt="Vinarium app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Vinarium · iOS <span class="proof-card__appstore" aria-label="Available on the App Store"><Icon name="simple-icons:appstore" /></span></p>
              <p class="proof-card__title">Manage your wine cellar.</p>
              <p class="proof-card__caption">AI, location, price, sharing and more.</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <PhoneCarousel
                  images={[
                    { src: dashboardShot, alt: 'Vinarium dashboard' },
                    { src: scanReviewShot, alt: 'AI-filled wine record' },
                    { src: cellarShot, alt: 'Cellar map' },
                  ]}
                />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.15}>
          <div class="proof-card proof-card--carnet proof-card--soon" data-category="ios">
            <span class="proof-card__ribbon">Coming soon</span>
            <span class="proof-card__date">Jul 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={carnetIcon}
                alt="Carnet app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Carnet · iOS</p>
              <p class="proof-card__title">Your culinary lab notebook.</p>
              <p class="proof-card__caption">
                Coffee, cocktails, dishes and Thermomix, tuned by AI.
              </p>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <PhoneCarousel
                  images={[
                    { src: carnetHome, alt: 'Carnet home, recipes being improved' },
                    { src: carnetRecipe, alt: 'Espresso recipe with the version to test' },
                    { src: carnetProposal, alt: 'AI proposing the next iteration' },
                  ]}
                />
              </IPhoneFrame>
            </div>
          </div>
        </Reveal>
        <Reveal delay={0.15}>
          <a
            class="proof-card proof-card--stats"
            href="https://github.com/moifort/minimal-stats"
            rel="noopener"
            data-category="macos"
          >
            <span class="proof-card__date">Feb 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={statsIcon}
                alt="Stats app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Stats · macOS</p>
              <p class="proof-card__title">Minimalist stats.</p>
              <p class="proof-card__caption">CPU, network, disk<br />and Claude usage<br />in the menu bar.</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__window" aria-hidden="true">
              <Image src={statsPopover} alt="" width={524} height={440} />
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.2}>
          <div class="proof-card proof-card--shield" data-category="3d-printing">
            <span class="proof-card__date">Jul 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={gridfinityIcon}
                alt="MakerWorld logo"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">3D print</p>
              <p class="proof-card__title">Shield any temperature sensor.</p>
              <p class="proof-card__caption">
                Radiation shield in white PETG. Prints without supports, snaps together without
                glue.
              </p>
            </div>
            <div class="proof-card__model" aria-hidden="true">
              <ModelViewer src="/models/sensor-shield.v1.glb" alt="" />
            </div>
          </div>
        </Reveal>
        <Reveal delay={0.25}>
          <a
            class="proof-card proof-card--gridfinity"
            href="https://makerworld.com/en/@moifort"
            rel="noopener"
            data-category="3d-printing"
          >
            <span class="proof-card__date">Jul 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={gridfinityIcon}
                alt="MakerWorld logo"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Gridfinity · MakerWorld</p>
              <p class="proof-card__title">Organization, leveled up.</p>
              <p class="proof-card__caption">Custom Gridfinity stuff.</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__model proof-card__model--gridfinity" aria-hidden="true">
              <ModelViewer
                sources={[
                  '/models/gridfinity-caliper.v1.glb',
                  '/models/gridfinity-civivi.v1.glb',
                  '/models/gridfinity-multimeter.v1.glb',
                  '/models/gridfinity-zanflare.v1.glb',
                ]}
                alt=""
                cameraOrbit="-32deg 52deg auto"
                autoRotate={false}
                environmentImage="legacy"
                exposure="0.75"
              />
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.3}>
          <a
            class="proof-card proof-card--bloomin8"
            href="https://github.com/moifort/bloomin8"
            rel="noopener"
            data-category="ios"
          >
            <span class="proof-card__date">Feb 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon proof-card__icon--b8"
                src={bloomin8Logo}
                alt="Bloomin8 logo"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Bloomin8 · iOS + Docker</p>
              <p class="proof-card__title">Fix a bad e-ink app.</p>
              <p class="proof-card__caption">Self-hosted server, bulk upload, playlists and a battery widget.</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame src={bloomin8Screen} alt="Bloomin8 Canvas app" />
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.3}>
          <a
            class="proof-card proof-card--homefan"
            href="https://github.com/moifort/homebridge-create-fan"
            rel="noopener"
            data-category="home-automation"
          >
            <span class="proof-card__date">Apr 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={homeIcon}
                alt="Apple Home app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Create Ceiling Fan · Homebridge</p>
              <p class="proof-card__title">Your ceiling fan, in HomeKit.</p>
              <p class="proof-card__caption">Speed, direction and light for CREATE fans, right from the Home app.</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame src={homeFanScreen} alt="CREATE ceiling fan in the Home app" />
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.35}>
          <a
            class="proof-card proof-card--dashboard"
            href="https://github.com/moifort/home-dashboard"
            rel="noopener"
            data-category="home-automation hardware"
          >
            <span class="proof-card__date">Feb 2026</span>
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={homeIcon}
                alt="Apple Home app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Home Dashboard · ESP32 + Docker</p>
              <p class="proof-card__title">Your home on e-paper.</p>
              <p class="proof-card__caption">
                Electricity, solar, water, plants and network.
              </p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__model proof-card__model--dashboard" aria-hidden="true">
              <ModelViewer
                src="/models/home-dashboard.v1.glb"
                alt=""
                cameraOrbit="40deg 74deg 62%"
                autoRotate={false}
                interactive={false}
              />
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.4}>
          <a
            class="proof-card proof-card--stockalert"
            href="https://github.com/moifort/stock-alert"
            rel="noopener"
            data-category="home-automation hardware"
          >
            <span class="proof-card__date">Jun 2026</span>
            <svg
              class="proof-card__matter"
              viewBox="0 0 338.667 72.644"
              xmlns="http://www.w3.org/2000/svg"
              role="img"
              aria-label="Works with Matter"
            >
              <path
                fill="currentColor"
