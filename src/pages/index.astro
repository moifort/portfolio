---
import type { ImageMetadata } from 'astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import arnaudImg from '../assets/influences/arnaud-lemaire.jpg'
import cyrilImg from '../assets/influences/cyril-martraire.jpg'
import davidImg from '../assets/influences/david-gageot.jpg'
import evansImg from '../assets/influences/eric-evans.jpg'
import fowlerImg from '../assets/influences/martin-fowler.jpg'
import mancusoImg from '../assets/influences/sandro-mancuso.jpg'
import mattImg from '../assets/influences/matt-pocock.jpg'
import robertImg from '../assets/influences/robert-martin.jpg'
import scottImg from '../assets/influences/scott-wlaschin.jpg'
import theoImg from '../assets/influences/theo.jpg'
import portrait from '../assets/portrait.jpg'
import appIcon from '../assets/vinarium/app-icon.png'
import cellarShot from '../assets/vinarium/cellar.png'
import dashboardShot from '../assets/vinarium/dashboard.png'
import scanReviewShot from '../assets/vinarium/scan-review.png'
import CryptoPhoneScreen from '../components/CryptoPhoneScreen.astro'
import PhoneCarousel from '../components/PhoneCarousel.astro'
import IPhoneFrame from '../components/IPhoneFrame.astro'
import Reveal from '../components/Reveal.astro'
import StatCounter from '../components/StatCounter.astro'
import cryptoIcon from '../assets/crypto-bot/app-icon.png'
import statsIcon from '../assets/stats/app-icon.png'
import statsPopover from '../assets/stats/popover.png'
import { cryptoBot, sinceLabel } from '../data/crypto-bot'
import { site } from '../data/site'
import Base from '../layouts/Base.astro'

const roles = [
  { icon: 'lucide:pen-tool', label: 'UI/UX' },
  { icon: 'lucide:monitor', label: 'Frontend' },
  { icon: 'lucide:server', label: 'Backend' },
  { icon: 'lucide:terminal', label: 'Ops' },
  { icon: 'lucide:shield', label: 'Security' },
  { icon: 'lucide:database', label: 'Data' },
  { icon: 'lucide:bug', label: 'QA' },
]

type Influence = {
  name: string
  url: string
  img?: ImageMetadata
  mono?: string
  emoji?: string
  items: { icon: string; label: string }[]
}

const influences: Influence[] = [
  {
    name: 'Scott Wlaschin',
    emoji: '😍',
    url: 'https://fsharpforfunandprofit.com',
    img: scottImg,
    items: [{ icon: 'lucide:book-open', label: 'Domain Modeling Made Functional' }],
  },
  {
    name: 'Eric Evans',
    url: 'https://www.domainlanguage.com',
    img: evansImg,
    items: [{ icon: 'lucide:book-open', label: 'Domain-Driven Design' }],
  },
  {
    name: 'Martin Fowler',
    url: 'https://martinfowler.com',
    img: fowlerImg,
    items: [
      { icon: 'lucide:book-open', label: 'Refactoring' },
      { icon: 'lucide:youtube', label: 'Conference talks' },
    ],
  },
  {
    name: 'Robert C. Martin',
    url: 'https://blog.cleancoder.com',
    img: robertImg,
    items: [{ icon: 'lucide:book-open', label: 'Clean Code' }],
  },
  {
    name: 'Sandro Mancuso',
    url: 'https://www.codurance.com',
    img: mancusoImg,
    items: [{ icon: 'lucide:book-open', label: 'The Software Craftsman' }],
  },
  {
    name: 'Cyril Martraire',
    url: 'https://www.livingdocumentation.net',
    img: cyrilImg,
    items: [{ icon: 'lucide:book-open', label: 'Living Documentation' }],
  },
  {
    name: 'Arnaud Lemaire',
    url: 'https://www.youtube.com/results?search_query=arnaud+lemaire+ddd',
    img: arnaudImg,
    items: [{ icon: 'lucide:mic', label: 'Talks' }],
  },
  {
    name: 'Jérémie Chassaing',
    url: 'https://www.youtube.com/results?search_query=jérémie+chassaing',
    mono: 'JC',
    items: [{ icon: 'lucide:mic', label: 'Talks' }],
  },
  {
    name: 'David Gageot',
    url: 'https://www.youtube.com/results?search_query=david+gageot',
    img: davidImg,
    items: [{ icon: 'lucide:mic', label: 'Talks' }],
  },
  {
    name: 'Theo (T3)',
    url: 'https://www.youtube.com/@t3dotgg',
    img: theoImg,
    items: [{ icon: 'lucide:youtube', label: 'YouTube channel' }],
  },
  {
    name: 'Matt Pocock',
    url: 'https://www.youtube.com/@mattpocockuk',
    img: mattImg,
    items: [{ icon: 'lucide:youtube', label: 'YouTube channel' }],
  },
]

const timeline = [
  {
    period: 'Since Jan. 2026',
    role: 'Paternity leave',
    note: 'shipping CryptoBot & Vinarium with Claude',
    current: true,
  },
  {
    period: 'Jul. → Dec. 2025',
    role: 'Senior developer',
    note: 'Sunday',
  },
  {
    period: '2018 · 2025',
    role: 'Freelance full-stack developer & lead tech',
    note: 'remote, abroad',
  },
  { period: '2017 · 2018', role: 'CTO', note: 'pupscan.com' },
  { period: '2016 · 2017', role: 'Web developer', note: 'Société Générale' },
  { period: '2014 · 2016', role: 'CTO', note: 'alantaya.com' },
]
---

<Base
  title="Thibaut Mottet · Senior full-stack developer, the impact of a whole team"
  description="AI is changing software development. I bring the method, the architecture and the product vision, Claude writes the code. Real products in production, used every day."
  theme="home"
>
  <!-- Act 1 · Hero -->
  <header class="hero">
    <div class="container hero__inner">
      <div class="hero__top">
      <Reveal delay={0.15} class="hero__card-wrap">
        <aside class="profile-card">
          <span class="profile-card__status">
            <span class="profile-card__status-dot"></span>
            Open to new missions
          </span>
          <div class="profile-card__head">
            <Image
              class="profile-card__avatar"
              src={portrait}
              alt="Portrait of Thibaut Mottet"
              width={160}
              height={160}
              loading="eager"
              fetchpriority="high"
            />
            <div class="profile-card__id">
              <strong>{site.name}</strong>
              <span>{site.role}</span>
              <span class="profile-card__location">
                <Icon name="lucide:map-pin" />
                {site.location}
              </span>
            </div>
            <div class="profile-card__links">
              <a href={site.github} rel="noopener" aria-label="GitHub">
                <Icon name="lucide:github" />
              </a>
              <a href={`mailto:${site.email}`} aria-label="Email">
                <Icon name="lucide:mail" />
              </a>
            </div>
          </div>
          <ol class="profile-card__timeline">
            {
              timeline.map((t) => (
                <li class:list={['tl-entry', { 'is-current': t.current }]}>
                  <span class="profile-card__period">{t.period}</span>
                  <strong>{t.role}</strong>
                  <span class="profile-card__note">{t.note}</span>
                </li>
              ))
            }
            <li class="tl-gap" aria-hidden="true">
              <span>a lot happened…</span>
            </li>
            <li class="tl-birth">
              <span class="profile-card__period">1985</span>
              <strong>Born <span class="tl-baby">👶</span></strong>
            </li>
          </ol>
          <div class="profile-card__offer">
            <p class="profile-card__price">
              <strong>{site.dailyRate}&nbsp;€</strong><span>/ day</span>
            </p>
            <a class="profile-card__cta" href={`mailto:${site.email}`}>
              Hire me <Icon name="lucide:arrow-right" />
            </a>
          </div>
        </aside>
        <aside class="influences-card">
          <p class="influences-card__eyebrow">Influences</p>
          <ul class="influences-card__list">
            {
              influences.map((person) => (
                <li class="influences-card__row">
                  {person.img ? (
                    <Image
                      class="influences-card__avatar"
                      src={person.img}
                      alt={`Portrait of ${person.name}`}
                      width={120}
                      height={120}
                    />
                  ) : (
                    <span class="influences-card__avatar influences-card__mono">{person.mono}</span>
                  )}
                  <div class="influences-card__info">
                    <a href={person.url} rel="noopener">
                      {person.name}
                      {person.emoji && <span class="influences-card__emoji">{person.emoji}</span>}
                    </a>
                    <ul class="influences-card__items">
                      {
                        person.items.map((item) => (
                          <li>
                            <Icon name={item.icon} />
                            {item.label}
                          </li>
                        ))
                      }
                    </ul>
                  </div>
                </li>
              ))
            }
          </ul>
        </aside>
      </Reveal>
      <div class="hero__right">
        <div class="hero__text">
          <Reveal delay={0.08}>
            <h1 class="display">
              One senior developer.<br />The impact of a <span class="display__grad"
                >whole team</span
              >.
            </h1>
          </Reveal>
          <Reveal delay={0.15}>
            <p class="hero__lede">
              AI is changing our job, let's not pretend otherwise. What it still lacks is method,
              architecture and product vision. On my own, I now have a full team at my disposal:
            </p>
          </Reveal>
          <Reveal delay={0.2}>
            <ul class="hero__roles" aria-label="Roles I cover">
              {
                roles.map((r) => (
                  <li class="hero__role">
                    <Icon name={r.icon} />
                    {r.label}
                  </li>
                ))
              }
            </ul>
          </Reveal>
        </div>
        <div class="proof__grid" id="proof">
          <Reveal>
          <a class="proof-card proof-card--crypto" href="/crypto-bot">
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={cryptoIcon}
                alt="CryptoBot app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">CryptoBot · iOS</p>
              <p class="proof-card__stat proof-card__stat--sm">
                <StatCounter value={cryptoBot.netPercent} decimals={2} prefix="+" suffix="%" />
              </p>
              <p class="proof-card__caption">
                net since {sinceLabel} · holding BTC:
                <span class="hold-down">▼&nbsp;{Math.abs(cryptoBot.holdPercent)}%</span>
              </p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <CryptoPhoneScreen />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.1}>
          <a class="proof-card proof-card--vinarium" href="/vinarium">
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={appIcon}
                alt="Vinarium app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Vinarium · iOS</p>
              <p class="proof-card__title">Manage your wine cellar.</p>
              <p class="proof-card__caption">AI, location, price, sharing and more.</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__phone" aria-hidden="true">
              <IPhoneFrame>
                <PhoneCarousel
                  images={[
                    { src: dashboardShot, alt: 'Vinarium dashboard' },
                    { src: scanReviewShot, alt: 'AI-filled wine record' },
                    { src: cellarShot, alt: 'Cellar map' },
                  ]}
                />
              </IPhoneFrame>
            </div>
          </a>
        </Reveal>
        <Reveal delay={0.15}>
          <a
            class="proof-card proof-card--stats"
            href="https://github.com/moifort/minimal-stats"
            rel="noopener"
          >
            <div class="proof-card__body">
              <Image
                class="proof-card__icon"
                src={statsIcon}
                alt="Stats app icon"
                width={200}
                height={200}
              />
              <p class="proof-card__eyebrow">Stats · macOS</p>
              <p class="proof-card__title">Minimalist stats.</p>
              <p class="proof-card__caption">CPU, network, disk and Claude usage in the menu bar.</p>
              <span class="proof-card__cta">See more →</span>
            </div>
            <div class="proof-card__window" aria-hidden="true">
              <Image src={statsPopover} alt="" width={524} height={440} />
            </div>
          </a>
        </Reveal>
        </div>
      </div>
      </div>
    </div>
  </header>
</Base>

<style>
  .hero {
    display: grid;
    align-items: center;
    min-height: 100svh;
    padding-block: clamp(2rem, 5vh, 4rem);
    position: relative;
    overflow: clip;
    background:
      radial-gradient(55% 45% at 88% 12%, rgba(48, 209, 88, 0.14) 0%, transparent 65%),
      radial-gradient(45% 40% at 8% 88%, rgba(114, 47, 55, 0.12) 0%, transparent 65%),
      var(--bg);
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero__top {
    display: grid;
    grid-template-columns: minmax(0, 22rem) 1fr;
    align-items: stretch;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  :global(.hero__card-wrap) {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  .profile-card {
    flex: 1;
  }

  /* Influences card, under the profile card */
  .influences-card {
    padding: 1.4rem 1.6rem;
    border-radius: 1.5rem;
    border: 1px solid var(--border);
    background: var(--card);
    box-shadow: 0 28px 56px -28px rgba(38, 34, 26, 0.22);
  }

  .influences-card__eyebrow {
    font-size: 0.7188rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.9rem;
  }

  .influences-card__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .influences-card__row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  :global(.influences-card__avatar) {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 0 0 2px rgba(38, 34, 26, 0.08);
  }

  .influences-card__mono {
    display: grid;
    place-items: center;
    background: linear-gradient(150deg, #3a5a8c, #24406b);
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
  }

  .influences-card__emoji {
    margin-left: 0.3rem;
  }

  .influences-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .influences-card__info > a {
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    color: var(--text);
    text-decoration: none;
  }

  .influences-card__info > a:hover {
    text-decoration: underline;
  }

  .influences-card__items {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    column-gap: 0.9rem;
    row-gap: 0.15rem;
  }

  .influences-card__items li {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8438rem;
    color: var(--muted);
  }

  .influences-card__items [data-icon] {
    width: 0.9em;
    height: 0.9em;
    color: var(--accent);
    flex-shrink: 0;
  }

  .hero__right {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    min-width: 0;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    padding-top: clamp(0.5rem, 3vh, 2.5rem);
  }

  @media (max-width: 900px) {
    .hero__top {
      grid-template-columns: 1fr;
    }

    .hero__right {
      order: 2;
    }

    .hero__text {
      align-items: center;
      text-align: center;
    }

    :global(.hero__card-wrap) {
      order: 1;
      width: min(26rem, 100%);
      margin-inline: auto;
    }
  }

  .hero__lede {
    max-width: 40rem;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.7;
    color: var(--text);
    text-wrap: pretty;
  }

  .hero__roles {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .hero__role {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .hero__role [data-icon] {
    width: 1em;
    height: 1em;
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .hero__roles {
      justify-content: center;
    }
  }

  .hero :global(.display) {
    font-size: clamp(2rem, 3.4vw, 3.35rem);
    line-height: 1.08;
    text-wrap: balance;
  }

  .display__grad {
    background: linear-gradient(100deg, #1fa348 0%, #30d158 45%, #a4484f 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  @media (max-width: 820px) {
    .roles {
      justify-content: center;
    }
  }

  /* Profile card: light, clean, like a product card */
  .profile-card {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 1.6rem;
    border-radius: 1.5rem;
    color: var(--text);
    border: 1px solid var(--border);
    background: var(--card);
    box-shadow: 0 28px 56px -28px rgba(38, 34, 26, 0.22);
  }

  .profile-card__status {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.85rem;
    margin-bottom: 1.1rem;
    border-radius: 999px;
    background: rgba(48, 209, 88, 0.12);
    color: var(--green);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .profile-card__status-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }

  .profile-card__head {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  :global(.profile-card__avatar) {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 2px rgba(38, 34, 26, 0.08);
  }

  .profile-card__id {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.35;
  }

  .profile-card__id strong {
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
  }

  .profile-card__id span {
    font-size: 0.8438rem;
    color: var(--muted);
  }

  .profile-card__location {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .profile-card__location [data-icon] {
    width: 0.85em;
    height: 0.85em;
  }

  .profile-card__links {
    margin-left: auto;
    display: flex;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .profile-card__links a {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.65rem;
    border: 1px solid var(--border);
    color: var(--text);
    transition: background-color 0.2s;
  }

  .profile-card__links a:hover {
    background: rgba(38, 34, 26, 0.05);
  }

  .profile-card__links [data-icon] {
    width: 1rem;
    height: 1rem;
  }

  .profile-card__timeline {
    list-style: none;
    padding: 0;
    margin-top: 1.4rem;
    border-top: 1px solid var(--border);
    padding-top: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
  }

  .profile-card__timeline li {
    position: relative;
    padding-left: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .profile-card__timeline li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #c4bcab;
  }

  .profile-card__timeline li.is-current::before {
    background: var(--accent);
    box-shadow: 0 0 8px rgba(30, 125, 67, 0.45);
  }

  .profile-card__timeline li:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 3px;
    top: 1.1rem;
    bottom: -1.05rem;
    width: 1px;
    background: var(--border);
  }

  /* Birth entry (bottom of the timeline, chronological origin) */
  .tl-birth::before {
    background: var(--gold);
  }

  .tl-baby {
    font-size: 0.95em;
  }

  /* the last career entry connects to birth via the dashed gap, not a solid line */
  .tl-entry:has(+ .tl-gap)::after {
    display: none;
  }

  /* Dashed "a lot happened" gap between the earliest job and birth */
  .tl-gap {
    min-height: 2.4rem;
    justify-content: center;
    padding-left: 1.15rem;
  }

  .tl-gap::before {
    display: none;
  }

  .tl-gap::after {
    content: '';
    position: absolute;
    left: 3px;
    top: -1.4rem;
    bottom: -1.4rem;
    width: 0;
    border-left: 2px dashed color-mix(in srgb, var(--muted) 55%, transparent);
    background: none;
  }

  .tl-gap > span {
    font-size: 0.7188rem;
    font-style: italic;
    color: color-mix(in srgb, var(--muted) 80%, transparent);
  }

  .profile-card__period {
    font-size: 0.7188rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .profile-card__timeline strong {
    font-size: 0.9063rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .profile-card__note {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  /* price + CTA, like a product card */
  .profile-card__offer {
    margin-top: auto;
    padding-top: 1.3rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .profile-card__price strong {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

