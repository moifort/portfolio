---
import { Image } from 'astro:assets'
import appIcon from '../assets/vinarium/app-icon.png'
import cellarShot from '../assets/vinarium/cellar.png'
import dashboardShot from '../assets/vinarium/dashboard.png'
import journalShot from '../assets/vinarium/journal.png'
import scanReviewShot from '../assets/vinarium/scan-review.png'
import scanShot from '../assets/vinarium/scan.png'
import widgetCave from '../assets/vinarium/widget-en-cave.png'
import widgetJournal from '../assets/vinarium/widget-journal.png'
import widgetReady from '../assets/vinarium/widget-pret-a-deguster.png'
import widgetValue from '../assets/vinarium/widget-valeur.png'
import wineDetailShot from '../assets/vinarium/wine-detail.png'
import wineListShot from '../assets/vinarium/wine-list.png'

const widgets = [
  { src: widgetValue, label: 'Cellar value', alt: 'iOS widget showing total cellar value' },
  { src: widgetCave, label: 'In the cellar', alt: 'iOS widget showing bottles in the cellar' },
  { src: widgetReady, label: 'Ready to drink', alt: 'iOS widget showing wines ready to drink' },
  { src: widgetJournal, label: 'Journal', alt: 'iOS widget showing latest cellar activity' },
]
import IPhoneFrame from '../components/IPhoneFrame.astro'
import Reveal from '../components/Reveal.astro'
import SiteFooter from '../components/SiteFooter.astro'
import { site } from '../data/site'
import Base from '../layouts/Base.astro'
---

<Base
  title="Vinarium — Your cellar, understood."
  description="A native iOS wine cellar app. Photograph a label: Claude reads it, Gemini estimates the price. Physical cellar map, live value, drink windows. Built by supervising Claude."
  theme="vinarium"
>
  <!-- Hero -->
  <header class="hero">
    <Image
      class="hero__backdrop"
      src={appIcon}
      alt=""
      width={640}
      height={640}
      aria-hidden="true"
    />
    <div class="container hero__inner">
      <div class="hero__text">
        <Reveal>
          <div class="hero__brand">
            <Image class="hero__icon" src={appIcon} alt="Vinarium app icon" width={160} height={160} />
            <p class="eyebrow">Vinarium · native iOS</p>
          </div>
        </Reveal>
        <Reveal delay={0.1}>
          <h1 class="display">Your cellar,<br />understood.</h1>
        </Reveal>
        <Reveal delay={0.2}>
          <p class="lede hero__lede">
            Every bottle scanned, located, valued — and opened at its peak. A wine cellar that
            finally knows itself.
          </p>
        </Reveal>
      </div>
      <Reveal delay={0.2} class="hero__phone">
        <IPhoneFrame src={dashboardShot} alt="Vinarium dashboard: bottles in cellar, total value, ready-to-drink list" priority />
      </Reveal>
    </div>
  </header>

  <!-- The magic trick: AI scan -->
  <section class="section scan">
    <div class="container">
      <Reveal><p class="eyebrow">The magic trick</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">Point. Shoot. Cellared.</h2>
      </Reveal>
      <Reveal delay={0.1}>
        <p class="lede scan__lede">
          Photograph any label. <strong>Claude</strong> reads it — producer, appellation, vintage,
          grape varieties. <strong>Gemini</strong> scours the web and estimates the price. You
          glance, confirm, done: a complete cellar record in seconds.
        </p>
      </Reveal>
      <div class="scan__duo">
        <Reveal class="scan__phone scan__phone--left">
          <IPhoneFrame src={scanShot} alt="Vinarium camera view scanning a wine label" />
        </Reveal>
        <Reveal delay={0.15} class="scan__arrow-wrap">
          <span class="scan__arrow" aria-hidden="true">→</span>
        </Reveal>
        <Reveal delay={0.25} class="scan__phone scan__phone--right">
          <IPhoneFrame src={scanReviewShot} alt="Scan result: a fully pre-filled wine record with estimated price" />
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section">
    <div class="container features">
      <div class="feature">
        <div class="feature__text">
          <Reveal><h2 class="headline">Every bottle has an address.</h2></Reveal>
          <Reveal delay={0.08}>
            <p class="feature__copy">
              Row A, column 4. Vinarium mirrors your physical cellar, bottle by bottle — so you
              grab the right one without lifting ten others.
            </p>
          </Reveal>
        </div>
        <Reveal class="feature__phone">
          <IPhoneFrame src={cellarShot} alt="Physical cellar map with bottles by row and column" />
        </Reveal>
      </div>

      <div class="feature feature--flip">
        <div class="feature__text">
          <Reveal><h2 class="headline">Your cellar's worth, live.</h2></Reveal>
          <Reveal delay={0.08}>
            <p class="feature__copy">
              Total value, bottles in stock, what deserves attention — one glance. And when a wine
              enters its drink window, Vinarium flags it <em>before</em> it's too late. Right on
              your home screen, with widgets.
            </p>
          </Reveal>
        </div>
        <Reveal class="feature__phone">
          <IPhoneFrame src={wineListShot} alt="Wine collection with prices, filters and favorites" />
        </Reveal>
      </div>

      <div class="feature">
        <div class="feature__text">
          <Reveal><h2 class="headline">A sommelier's memory.</h2></Reveal>
          <Reveal delay={0.08}>
            <p class="feature__copy">
              Grapes, appellations, classifications, purchase price, tasting notes, gifts given and
              received. Everything a bottle can tell, structured and searchable.
            </p>
          </Reveal>
        </div>
        <Reveal class="feature__phone">
          <IPhoneFrame src={wineDetailShot} alt="Wine detail: color, estate, vintage, appellation, classification, grapes" />
        </Reveal>
      </div>

      <div class="feature feature--flip">
        <div class="feature__text">
          <Reveal><h2 class="headline">In and out, remembered.</h2></Reveal>
          <Reveal delay={0.08}>
            <p class="feature__copy">
              Every bottle that enters or leaves, dated and noted. Your cellar's story writes
              itself.
            </p>
          </Reveal>
        </div>
        <Reveal class="feature__phone">
          <IPhoneFrame src={journalShot} alt="Journal of cellar entries and exits by date" />
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Widgets -->
  <section class="section widgets">
    <div class="container">
      <Reveal><p class="eyebrow">On your home screen</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">Your cellar, without opening the app.</h2>
      </Reveal>
      <Reveal group class="widgets__grid">
        {
          widgets.map((w) => (
            <figure class="widgets__item">
              <Image src={w.src} alt={w.alt} width={480} height={480} />
              <figcaption>{w.label}</figcaption>
            </figure>
          ))
        }
      </Reveal>
    </div>
  </section>

  <!-- Everything else -->
  <section class="section">
    <div class="container">
      <Reveal><p class="eyebrow">And everything else</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">Deep where a collection needs it.</h2>
      </Reveal>
      <Reveal group class="extras__grid">
        <div class="card extras__item">
          <h3>Global search</h3>
          <p>
            One search across names, producers, regions, vintages, even people — ranked by
            relevance, refined with combinable filter chips.
          </p>
        </div>
        <div class="card extras__item">
          <h3>Drink windows</h3>
          <p>
            Every wine carries its window. "Before 2027" is a promise the app keeps for you — the
            dashboard surfaces what's ready.
          </p>
        </div>
        <div class="card extras__item">
          <h3>Gifts, both ways</h3>
          <p>
            Bottles received and bottles offered, tracked with who and when. Never re-gift a wine
            to the person who gave it to you.
          </p>
        </div>
        <div class="card extras__item">
          <h3>Beyond wine</h3>
          <p>
            Port, rum, sake, beer — structured subtypes for any bottle worth keeping, with the
            same care as a grand cru.
          </p>
        </div>
        <div class="card extras__item">
          <h3>Tasting journal</h3>
          <p>
            Notes and ratings on every bottle opened. Your palate's history, searchable.
          </p>
        </div>
        <div class="card extras__item">
          <h3>Your data, yours</h3>
          <p>
            Full JSON export and import. Sign in with Apple, per-user isolation in Firestore — and
            an exit door, always.
          </p>
        </div>
      </Reveal>
    </div>
  </section>

  <Reveal>
    <p class="french-note container--narrow">
      Oui — the app speaks French. Wine tastes better in its native language.
    </p>
  </Reveal>

  <!-- The craft -->
  <section class="section">
    <div class="container--narrow craft">
      <Reveal><p class="eyebrow">The craft</p></Reveal>
      <Reveal delay={0.05}>
        <h2 class="headline">Two AIs in production.<br />One command to deploy it all.</h2>
      </Reveal>
      <Reveal group class="craft__chips">
        <span>SwiftUI · Swift 6</span><span>iOS 26</span><span>GraphQL typed end-to-end</span>
        <span>Nitro on Cloud Functions</span><span>Firestore</span><span>DDD &amp; CQRS</span>
        <span>Pure FP core</span><span>Terraform one-shot</span><span>Claude vision</span>
        <span>Gemini search</span>
      </Reveal>
      <Reveal>
        <p class="craft__copy">
          Same method as everything I ship: domain-driven design with strict CQRS, business rules
          as pure functions — 100% tested — and a GraphQL schema typed end-to-end, from Firestore
          to SwiftUI. The entire GCP/Firebase infrastructure bootstraps with one Terraform command.
          Architecture and reviews by me — the code written by Claude, under close supervision.
        </p>
      </Reveal>
      <Reveal delay={0.1}>
        <div class="craft__actions">
          <a class="btn btn--primary" href="/">Read how I work</a>
          <a class="btn btn--ghost" href={site.github} rel="noopener">GitHub</a>
        </div>
      </Reveal>
    </div>
  </section>

  <SiteFooter backLink />
</Base>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    align-items: center;
    padding-block: 5rem;
    position: relative;
    overflow: clip;
    background: radial-gradient(90% 65% at 75% 5%, rgba(114, 47, 55, 0.4) 0%, transparent 62%),
      radial-gradient(60% 40% at 10% 90%, rgba(201, 162, 39, 0.1) 0%, transparent 60%), var(--bg);
  }

  /* the app icon, blown up and blurred, as an ambient backdrop */
  :global(.hero__backdrop) {
    position: absolute;
    top: -12%;
    left: -14%;
    width: min(56vw, 780px);
    height: auto;
    filter: blur(90px) saturate(1.3);
    opacity: 0.32;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: 3rem;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .hero__brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* :global — classes on component-rendered elements (Reveal/Image) miss the scope hash */
  :global(.hero__icon) {
    width: 4rem;
    height: 4rem;
    border-radius: 0.95rem;
    box-shadow: 0 12px 28px -10px rgba(0, 0, 0, 0.6);
  }

  .hero__lede {
    max-width: 30rem;
  }

  :global(.hero__phone) {
    justify-self: center;
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .hero__text {
      align-items: center;
    }

    .hero__brand {
      flex-direction: column;
    }
  }

  /* Scan */
  .scan {
    text-align: center;
  }

  .scan__lede {
    max-width: 42rem;
    margin-inline: auto;
    margin-top: 1.25rem;
  }

  .scan__lede strong {
    color: var(--text);
  }

  .scan__duo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 4vw, 3rem);
    margin-top: 4rem;
    flex-wrap: wrap;
  }

  :global(.scan__phone--left .iphone) {
    rotate: -4deg;
  }

  :global(.scan__phone--right .iphone) {
    rotate: 4deg;
  }

  .scan__arrow {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--accent);
    font-weight: 700;
  }

  /* Features */
  .features {
    display: flex;
    flex-direction: column;
    gap: var(--section-gap);
  }

  .feature {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }

  .feature--flip {
    grid-template-columns: auto 1fr;
  }

  .feature--flip .feature__text {
    order: 2;
  }

  .feature--flip :global(.feature__phone) {
    order: 1;
  }

  .feature__copy {
    color: var(--muted);
    font-size: clamp(1.0625rem, 1.7vw, 1.25rem);
    line-height: 1.7;
    max-width: 30rem;
    margin-top: 1.25rem;
  }

  .feature__copy em {
    color: var(--text);
    font-style: italic;
  }

  @media (max-width: 820px) {
    .feature,
    .feature--flip {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .feature--flip .feature__text {
      order: 1;
    }

    .feature--flip .feature__phone {
      order: 2;
    }
  }

  /* Widgets */
  .widgets {
    text-align: center;
  }

  :global(.widgets__grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .widgets__item {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    align-items: center;
  }

  .widgets__item :global(img) {
    width: 100%;
    max-width: 15rem;
    height: auto;
    border-radius: 1.75rem;
    box-shadow: 0 24px 48px -20px rgba(0, 0, 0, 0.55);
  }

  .widgets__item figcaption {
    color: var(--muted);
    font-size: 0.9375rem;
    font-weight: 550;
  }

  /* Extras */
  :global(.extras__grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .extras__item {
    padding: 1.75rem;
  }

  .extras__item h3 {
    font-size: 1.125rem;
    font-weight: 750;
    letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
  }

  .extras__item p {
    color: var(--muted);
    font-size: 0.9688rem;
    line-height: 1.6;
  }

  .french-note {
    text-align: center;
    color: var(--muted);
    font-style: italic;
    font-size: 1.0625rem;
  }

  /* Craft */
  .craft {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  :global(.craft__chips) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  :global(.craft__chips) span {
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 0.9375rem;
    font-weight: 550;
  }

  .craft__copy {
    color: var(--muted);
    font-size: 1.125rem;
    line-height: 1.7;
  }

  .craft__actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
  }
</style>
