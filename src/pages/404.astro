---
import SiteFooter from '../components/SiteFooter.astro'
import Base from '../layouts/Base.astro'
---

<Base title="404 · Thibaut Mottet" description="Page not found." theme="home">
  <section class="notfound">
    <div class="container--narrow notfound__inner">
      <p class="eyebrow">404</p>
      <h1 class="headline">This page does not exist.</h1>
      <a class="btn btn--primary" href="/">Back home</a>
    </div>
  </section>
  <SiteFooter />
</Base>

<style>
  .notfound {
    min-height: 60svh;
    display: grid;
    place-items: center;
    padding-block: 6rem;
  }

  .notfound__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
</style>
